dding: 0; transition: all 0.12s; flex-shrink: 0;\n}\n.notif-panel-collapse:hover { background: rgba(255,255,255,0.16); color: #fff; border-color: rgba(255,255,255,0.3); }\n.notif-panel-collapse svg { width: 11px; height: 11px; }\n.notif-panel.collapsed .notif-panel-collapse svg { transform: rotate(180deg); }\n.notif-panel.collapsed .notif-panel-vert {\n  position: absolute; top: 60px; left: 50%;\n  transform: translate(-50%) rotate(-90deg); transform-origin: center;\n  white-space: nowrap;\n  font-family: var(--mono); font-size: 9px; font-weight: 700;\n  letter-spacing: 0.16em; text-transform: uppercase;\n  color: var(--text-muted); pointer-events: none;\n}\n.notif-panel:not(.collapsed) .notif-panel-vert { display: none; }\n\n/* Stew runner table — content-matched to live stewards-system layout */\n.stew-thead, .stew-row {\n  display: grid;\n  grid-template-columns: 22px 42px minmax(230px, 1.4fr) 100px minmax(150px, 1.1fr) minmax(110px, 0.9fr) 26px;\n  gap: 10px; align-items: center;\n  padding: 12px 16px;\n  position: relative;\n}\n.stew-thead {\n  background: var(--navy);\n  color: rgba(255,255,255,0.5);\n  font-size: 10px; font-weight: 600;\n  letter-spacing: 0.1em; text-transform: uppercase; font-family: var(--mono);\n  padding: 8px 16px;\n}\n.stew-row { border-bottom: 1px solid var(--border); cursor: pointer; transition: background 0.1s; }\n.stew-row:last-child { border-bottom: none; }\n.stew-row:hover { background: var(--blue-light); }\n.stew-row.flagged { background: var(--amber-light); }\n.stew-row.nr {\n  background: repeating-linear-gradient(135deg, transparent 0 11px, rgba(33,33,33,0.06) 11px 12px);\n  color: var(--text-muted);\n  cursor: default;\n}\n.stew-row.nr:hover { background: repeating-linear-gradient(135deg, transparent 0 11px, rgba(33,33,33,0.08) 11px 12px); }\n.stew-row.nr .stew-horse-name { color: var(--text-muted); }\n\n.stew-num { font-family: var(--mono); font-size: 13px; font-weight: 600; color: var(--text-muted); text-align: center; }\n\n