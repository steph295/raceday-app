 _syncAll(menuId) {\n  const menu = document.getElementById(menuId);\n  if (!menu) return;\n  const all = menu.querySelector('.fb-check-all input');\n  if (!all) return;\n  const items = [...menu.querySelectorAll('input[type=checkbox]')].filter(i => i !== all);\n  const on = items.filter(i => i.checked).length;\n  all.checked = on === items.length;\n  all.indeterminate = on > 0 && on < items.length;\n}\nfunction toggleAllInMenu(menuId, master) {\n  const target = master.checked;            // capture before loop (children re-sync the master)\n  const menu = document.getElementById(menuId);\n  menu.querySelectorAll('input[type=checkbox]').forEach(inp => {\n    if (inp === master || inp.dataset.noall) return;\n    if (inp.checked !== target) { inp.checked = target; inp.dispatchEvent(new Event('change')); }\n  });\n  master.checked = target; master.indeterminate = false;\n}\nfunction toggleFbPrices() {\n  const btn = document.getElementById('fbPricesBtn');\n  const hidden = document.body.classList.toggle('sds-hide-sp');\n  btn.classList.toggle('on', !hidden);\n  applySdsGrid();\n}\nfunction togglePriv(key, input) {\n  document.body.classList.toggle('show-priv-' + key, input.checked);\n  _syncAll('fbPrivMenu');\n}\n\n/* Combine horse + course history, sorted most-recent first (Today entries first) */\nfunction _sdsCombinedHorseHistory(meta) {\n  const items = [].concat(meta.history.horse || [], meta.history.course || []);\n  // Sort: today first, then chronological by parsing dd/mm/yy\n  const score = i => {\n    if (i.today) return 1e9;\n    const m = (i.date||'').match(/(\\d\\d)\\/(\\d\\d)\\/(\\d\\d)/);\n    if (!m) return 0;\n    return parseInt('20' + m[3]) * 10000 + parseInt(m[2]) * 100 + parseInt(m[1]);\n  };\n  return items.slice().sort((a, b) => score(b) - score(a));\n}\n\nlet sdsCommentCount = 2;\nfunction sdsSetCommentCount(v) {\n  sdsCommentCount = parseInt(v, 10) || 1;\n  renderHorseCommentsCells();\n}\n\nfunction renderHorseCommentsCells() {\n  document.querySelectorAll('#view-steward-daysheet .sds-col-horse[data-row-horse]').forEach(cell => {\n    const horseName = cell.dataset.rowHorse;\n    const meta = sdsRunnerMeta[horseName];\n    if (!meta) { cell.innerHTML = ''; return; }\n    const items = _sdsCombinedHorseHistory(meta).slice(0, sdsCommentCount);\n    if (!items.length) { cell.innerHTML = ''; return; }\n    cell.innerHTML = items.map(i => {\n      const tag = i.tag ? '<span class=\"hc-tag ' + i.tag + '\">' + (i.tag === 'warn' ? '⚠' : i.tag === 'cleared' ? '✓' : i.tag === 'course' ? '◆' : '●') + '<\u002Fspan>' : '';\n      return '<div class=\"hc-item ' + (i.today ? 'is-today' : '') + '\">' +\n        '<span class=\"hc-date\">' + _sdsEsc(i.date) + '<\u002Fspan>' + tag + _sdsEsc(i.text) +\n        '<\u002Fdiv>';\n    }).join('');\n  });\n}\n\n/* Build the grid template based on which columns are on */\nconst SDS_COL_DEFAULT = { exp: '36px', no: '28px', silk: '22px', jh: '200px', vet: '1fr', stew: '1fr', teams: '1fr', horse: '1.1fr', sp: '92px' };\nlet sdsColW = (function () { try { const s = JSON.parse(localStorage.getItem('sdsColW')); if (s && typeof s === 'object') return s; } catch (e) {} return {}; })();\nfunction _sdsW(key) { return sdsColW[key] || SDS_COL_DEFAULT[key]; }\nfunction saveSdsColW() { try { localStorage.setItem('sdsColW', JSON.stringify(sdsColW)); } catch (e) {} }\nfunction applySdsGrid() {\n  const showVet   = !document.body.classList.contains('sds-hide-vet');\n  const showStew  = !document.body.classList.contains('sds-hide-stew');\n  const showHorse = !document.body.classList.contains('sds-hide-horse');\n  const showSp    = !document.body.classList.contains('sds-hide-sp');\n  const showTeams = !document.body.classList.contains('sds-hide-teams');\n  const parts = [_sdsW('exp'), _sdsW('no'), _sdsW('silk'), _sdsW('jh')];\n  if (showVet)   parts.push(_sdsW('vet'));\n  if (showStew)  parts.push(_sdsW('stew'));\n  if (showTeams) parts.push(_sdsW('teams'));\n  if (showHorse) parts.push(_sdsW('horse'));\n  if (showSp)    parts.push(_sdsW('sp'));\n  const grid = parts.join(' ');\n  document.querySelectorAll('#view-steward-daysheet .sds-race .sds-row-head, #view-steward-daysheet .sds-race .ds-body > div').forEach(row => {\n    if (row.classList.contains('sds-history-row') || row.classList.contains('sds-clean-foot')) return;\n    if (!row.dataset.sdsDecorated && !row.classList.contains('sds-row-head')) return;\n    row.style.gridTemplateColumns = grid;\n  });\n  const head = document.getElementById('sdsTableHead');\n  if (head) head.style.gridTemplateColumns = grid;\n  updateSdsFilterCounts();\n  document.body.classList.toggle('sds-cols-resized', Object.keys(sdsColW).length > 0);\n}\n\nfunction ensureSdsTableHead() {\n  if (document.getElementById('sdsTableHead')) return;\n  const wrap = document.getElementById('sds-races');\n  if (!wrap) return;\n  const head = document.createElement('div');\n  head.id = 'sdsTableHead';\n  head.className = 'sds-table-head';\n  head.innerHTML =\n    '<div class=\"expand-col\" title=\"Expand/collapse all races\" onclick=\"sdsToggleAllFromHead()\"><svg viewBox=\"0 0 12 12\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"3,4.5 6,7.5 9,4.5\"/><\u002Fsvg><\u002Fdiv>' +\n    '<div>No.<\u002Fdiv>' +\n    '<div><\u002Fdiv>' +\n    '<div>Jockey / Horse<\u002Fdiv>' +\n    '<div class=\"sds-col-vet vet\">⚕ Vet notes<\u002Fdiv>' +\n    '<div class=\"sds-col-stew stew\">★ Steward notes<\u002Fdiv>' +\n    '<div class=\"sds-col-teams teams\">⊕ Other teams<\u002Fdiv>' +\n    '<div class=\"sds-col-horse horse\">◷ Horse comments<\u002Fdiv>' +\n    '<div class=\"sp\">SP<\u002Fdiv>';\n  const firstRace = wrap.querySelector('.sds-race');\n  if (firstRace) wrap.insertBefore(head, firstRace);\n  else wrap.appendChild(head);\n  attachSdsResizeHandles();\n}\n\n// Drag-to-resize for the steward day-sheet table (handles in the sticky header)\nfunction attachSdsResizeHandles() {\n  const head = document.getElementById('sdsTableHead');\n  if (!head) return;\n  // head cells, in order: exp, no, silk, jh, vet, stew, horse, sp\n  const keys = ['exp', 'no', 'silk', 'jh', 'vet', 'stew', 'horse', 'sp'];\n  const resizable = { jh: 1, vet: 1, stew: 1, horse: 1 };\n  const cells = head.children;\n  for (let i = 0; i < cells.length; i++) {\n    const key = keys[i];\n    if (!resizable[key]) continue;\n    const cell = cells[i];\n    if (cell.querySelector('.sds-resize')) continue;\n    cell.style.position = 'relative';\n    const h = document.createElement('div');\n    h.className = 'sds-resize';\n    h.title = 'Drag to resize · double-click to reset';\n    h.addEventListener('mousedown', ev => startSdsResize(ev, key, cell));\n    h.addEventListener('dblclick', ev => { ev.stopPropagation(); delete sdsColW[key]; saveSdsColW(); applySdsGrid(); });\n    cell.appendChild(h);\n  }\n}\nlet _sdsResize = null;\nfunction startSdsResize(e, key, cell) {\n  e.preventDefault(); e.stopPropagation();\n  _sdsResize = { key: key, startX: e.clientX, startW: cell.getBoundingClientRect().width };\n  document.body.classList.add('rc-resizing');\n  window.addEventListener('mousemove', onSdsResize);\n  window.addEventListener('mouseup', endSdsResize);\n}\nfunction onSdsResize(e) {\n  if (!_sdsResize) return;\n  const dx = e.clientX - _sdsResize.startX;\n  const w = Math.max(60, Math.round(_sdsResize.startW + dx));\n  sdsColW[_sdsResize.key] = w + 'px';\n  applySdsGrid();\n}\nfunction endSdsResize() {\n  if (!_sdsResize) return;\n  _sdsResize = null;\n  document.body.classList.remove('rc-resizing');\n  window.removeEventListener('mousemove', onSdsResize);\n  window.removeEventListener('mouseup', endSdsResize);\n  saveSdsColW();\n}\nfunction resetSdsColW() { sdsColW = {}; saveSdsColW(); applySdsGrid(); toast('Column widths reset', 'green'); }\n\nfunction sdsToggleAllFromHead() {\n  sdsToggleAllRaces();\n  // sync head's class to match overall state\n  const head = document.getElementById('sdsTableHead');\n  const anyCollapsed = [...document.querySelectorAll('#view-steward-daysheet .sds-race')].some(r => r.classList.contains('collapsed'));\n  if (head) head.classList.toggle('all-collapsed', anyCollapsed);\n}\n\nfunction ensureRaceChevrons() {\n  document.querySelectorAll('#sds-races .sds-race').forEach(race => {\n    const headRow = race.querySelector(':scope > div:first-child');\n    if (!headRow || headRow.querySelector('.sds-race-chevron')) return;\n    const chev = document.createElement('div');\n    chev.className = 'sds-race-chevron';\n    chev.innerHTML = '<svg viewBox=\"0 0 12 12\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"3,4.5 6,7.5 9,4.5\"/><\u002Fsvg>';\n    headRow.insertBefore(chev, headRow.firstChild);\n  });\n}\n\nfunction ensureRunnerIndent() {\n  document.querySelectorAll('#view-steward-daysheet .sds-race .ds-body > div').forEach(row => {\n    if (!row.dataset.sdsDecorated) return;\n    if (row.querySelector(':scope > .sds-row-indent')) return;\n    const ind = document.createElement('div');\n    ind.className = 'sds-row-indent';\n    ind.textContent = '↳';\n    row.insertBefore(ind, row.firstChild);\n  });\n}\n\nfunction updateSdsFilterCounts() {\n  // Vet/Steward: count cells with text content (excluding placeholder + headers)\n  const countCol = (cls) => {\n    let n = 0;\n    document.querySelectorAll('#view-steward-daysheet .sds-race .ds-body > div').forEach(row => {\n      if (row.classList.contains('sds-row-head') || row.classList.contains('sds-history-row') || row.classList.contains('sds-clean-foot')) return;\n      const cell = row.querySelector('.' + cls);\n      if (!cell) return;\n      const txt = (cell.textContent || '').trim();\n      if (txt && txt.length > 0 && !cell.hasAttribute('data-empty')) n++;\n    });\n    return n;\n  };\n  const v = countCol('sds-col-vet');\n  const s = countCol('sds-col-stew');\n  // Horse