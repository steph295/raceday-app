rp) {\n    grp.innerHTML =\n      '<option value=\"horse\">Horse — ' + horseFull + '<\u002Foption>' +\n      '<option value=\"jockey\">Jockey — J. Crowley<\u002Foption>' +\n      '<option value=\"trainer\">Trainer — A. Balding<\u002Foption>' +\n      '<option value=\"owner\">Owner — Juddmonte Farms<\u002Foption>';\n  }\n\n  // Reset form\n  document.getElementById('ce-subject').value = 'horse';\n  document.getElementById('ce-category').value = 'racecourse';\n  document.getElementById('ce-offence').value = '';\n  document.getElementById('ce-typeahead').classList.remove('open');\n\n  document.getElementById('createEnquiryModal').classList.add('open');\n}\n\nfunction ceCategoryChanged() {\n  // Clear offence selection when category changes\n  document.getElementById('ce-offence').value = '';\n  ceOffenceInput();\n}\n\nfunction ceOffenceInput() {\n  const cat = document.getElementById('ce-category').value;\n  const q = document.getElementById('ce-offence').value.trim().toLowerCase();\n  const list = CE_OFFENCES[cat] || [];\n  const filtered = q ? list.filter(o => o.label.toLowerCase().includes(q) || o.code.toLowerCase().includes(q)) : list;\n  const box = document.getElementById('ce-suggest');\n  if (!filtered.length) {\n    box.innerHTML = '<div class=\"ce-sug-empty\">No matching offences in this category.<\u002Fdiv>';\n  } else {\n    box.innerHTML = filtered.map(o =>\n      '<div class=\"ce-sug-item\" onmousedown=\"ceSelectOffence(\\''+o.code.replace(/'/g,\"\\\\'\")+'\\',\\''+o.label.replace(/'/g,\"\\\\'\")+'\\')\"><span>'+o.label+'<\u002Fspan><span class=\"ce-sug-code\">'+o.code+'<\u002Fspan><\u002Fdiv>'\n    ).join('');\n  }\n  document.getElementById('ce-typeahead').classList.add('open');\n}\n\nfunction ceSelectOffence(code, label) {\n  document.getElementById('ce-offence').value = code + ' — ' + label;\n  document.getElementById('ce-typeahead').classList.remove('open');\n}\n\nfunction submitCreateEnquiry() {\n  const subj = document.getElementById('ce-subject');\n  const subjLbl = subj.options[subj.selectedIndex].text;\n  const offence = document.getElementById('ce-offence').value.trim();\n  if (!offence) {\n    toast('Select an offence before saving','amber');\n    document.getElementById('ce-offence').focus();\n    return;\n  }\n  document.getElementById('createEnquiryModal').classList.remove('open');\n  toast('Enquiry opened against ' + subjLbl.replace(/^[^—]+— /,''), 'amber');\n}\n\nfunction dtToggle(row) {\n  if (row.classList.contains('compulsory')) return;\n  const wasSelected = row.classList.contains('selected');\n  row.classList.toggle('selected');\n  const check = row.querySelector('.dt-check');\n  if (row.classList.contains('selected')) {\n    check.textContent = '✓';\n    dtCount++;\n  } else {\n    check.textContent = '';\n    dtCount--;\n  }\n  const c = document.getElementById('dtCount');\n  c.textContent = dtCount;\n  c.className = dtCount >= 4 ? 'ok' : '';\n}\n\n// Override fire() so Steward's Simulate dropdown talks to the right log\nconst clerkFire = fire;\nfunction stFire(type, label, text, time, special) {\n  const scroll = document.getElementById('stNotifScroll');\n  const firstSection = scroll.querySelector('.notif-section-label');\n  const nid = 'stn' + Date.now();\n  const did = 'std' + Date.now();\n  const card = document.createElement('div');\n  card.className = `notif-card unread ${type} new`;\n  card.id = nid;\n  card.innerHTML = `\n    <div class=\"notif-header\">\n      <div class=\"nd ${type}\"><\u002Fdiv>\n      <div class=\"notif-type ${type}\">${label}<\u002Fdiv>\n      <div class=\"notif-unread-dot\" id=\"${did}\"><\u002Fdiv>\n    <\u002Fdiv>\n    <div class=\"notif-text\">${text}<\u002Fdiv>\n    <div class=\"notif-footer\">\n      <div class=\"notif-time\">${time}<\u002Fdiv>\n      <button class=\"notif-confirm\" onclick=\"stSeen('${nid}','${did}')\">✓ Seen<\u002Fbutton>\n    <\u002Fdiv>`;\n  firstSection.insertAdjacentElement('afterend', card);\n  stUnread++;\n  document.getElementById('stUnreadBadge').textContent = stUnread + ' new';\n  scroll.scrollTop = 0;\n}\n\n// Smart fire(): route by active role\nwindow.fire = function (type, label, text, time, isSSReceived) {\n  if (currentRole === 'steward') {\n    stFire(type, label, text, time);\n  } else {\n    clerkFire(type, label, text, time, isSSReceived);\n  }\n};\n\n// Day sheet flagged runner modal\nfunction openDsModal(horse, race, jockey, decl, flag, src, note) {\n  document.getElementById('ds-horse').textContent  = horse;\n  document.getElementById('ds-race').textContent   = race;\n  document.getElementById('ds-jockey').textContent = jockey;\n  document.getElementById('ds-decl').textContent   = decl;\n  document.getElementById('ds-flag').textContent   = flag;\n  document.getElementById('ds-src').textContent    = src;\n  document.getElementById('ds-note').textContent   = note;\n  document.getElementById('dsModal').classList.add('open');\n}\n\n// Bind day-sheet flagged rows → modal\nconst dsFlags = {\n  'H. Doyle':     {race:'Race 2 · Copper Horse Handicap',    horse:'Quickthorn (GB)',         decl:'9-0',  flag:'Stale data — Irish result overnight', src:'IHRB feed · expected 07:00',  note:'H. Doyle rode at Naas yesterday. Penalty may apply if winning ride detected. Awaiting morning batch from IHRB before clearing.'},\n  'J. Crowley':   {race:'Race 3 · Queen Anne Stakes',         horse:'Palace Pier (GB)',         decl:'8-11', flag:'Weight claim possibly changed',         src:'Result feed · Haydock 9 May', note:'J. Crowley won at Haydock yesterday. Claim may have changed 7lb → 5lb. Review declared weight before signing off.'},\n  'O. Murphy':    {race:'Race 4 · Coronation Stakes',         horse:'La Yakel (FR)',            decl:'8-9',  flag:'Overseas result not yet in system',     src:'France Galop feed pending',   note:'O. Murphy rode at Chantilly yesterday. Overseas result has not synced. Verify ride history before weigh-out.'},\n  'R. Kingscote': {race:'Race 6 · Diamond Jubilee Stakes',    horse:'Perfect Power (IRE)',      decl:'8-11', flag:'Penalty not applied — late UK result', src:'Wolverhampton 9 May 21:10',   note:'Late UK result missed the overnight batch. Penalty calculation may be incomplete — reapply before declarations close.'},\n  'C. Quinn':     {race:'Race 6 · Diamond Jubilee Stakes',    horse:'Highfield Princess (IRE)', decl:'8-11', flag:'Junior jockey claim to verify',         src:'Manual entry required',       note:'Junior jockey 3lb claim shown. Cross-check against career-rides count before clearing.'}\n};\ndocument.querySelectorAll('.ds-race .ds-body > div').forEach(row => {\n  const bg = (row.getAttribute('style') || '');\n  if (!bg.includes('amber-light')) return;\n  const txt = row.textContent;\n  const key = Object.keys(dsFlags).find(k => txt.includes(k));\n  if (!key) return;\n  row.style.cursor = 'pointer';\n  row.title = 'Click to review flag';\n  const d = dsFlags[key];\n  row.addEventListener('click', () => openDsModal(d.horse, d.race, key, d.decl, d.flag, d.src, d.note));\n  row.addEventListener('mouseenter', () => row.style.filter = 'brightness(0.97)');\n  row.addEventListener('mouseleave', () => row.style.filter = '');\n});\n\n// Toast\nlet toastTimer;\nfunction toast(msg, type) {\n  const t = document.getElementById('toastEl');\n  t.textContent = msg;\n  t.className = 'toast ' + (type || '');\n  void t.offsetWidth;\n  t.classList.add('show');\n  clearTimeout(toastTimer);\n  toastTimer = setTimeout(() => t.classList.remove('show'), 3500);\n}\n\n/* ─────  Sidecar notif-panel clone + collapse  ───── */\nfunction cloneNotifPanelInto(srcSelector, hostId, suffix, seenFnName) {\n  const src = document.querySelector(srcSelector);\n  const host = document.getElementById(hostId);\n  if (!src || !host || host.dataset.cloned) return;\n  const clone = src.cloneNode(true);\n  // Suffix all IDs in the clone\n  clone.querySelectorAll('[id]').forEach(el => { el.id = el.id + suffix; });\n  // Rewrite onclick handlers referencing the seen function so they target the new IDs\n  clone.querySelectorAll('[onclick]').forEach(el => {\n    let oc = el.getAttribute('onclick') || '';\n    oc = oc.replace(new RegExp('(' + seenFnName + \")\\\\(['\\\"]([\\\\w-]+)['\\\"]\\\\s*,\\\\s*['\\\"]([\\\\w-]+)['\\\"]\\\\)\", 'g'),\n      (m, fn, a, b) => fn + \"('\" + a + suffix + \"','\" + b + suffix + \"')\");\n    el.setAttribute('onclick', oc);\n  });\n  host.appendChild(clone);\n  host.dataset.cloned = '1';\n}\n\nfunction injectCollapseButtons() {\n  document.querySelectorAll('.notif-panel-head').forEach(head => {\n    if (head.querySelector('.notif-panel-collapse')) return;\n    const btn = document.createElement('button');\n    btn.className = 'notif-panel-collapse';\n    btn.title = 'Collapse';\n    btn.setAttribute('onclick', 'toggleNotifPanel()');\n    btn.setAttribute('aria-label', 'Toggle log');\n    btn.innerHTML = '<svg viewBox=\"0 0 12 12\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"7,3 3,6 7,9\"/><\u002Fsvg>';\n    head.insertBefore(btn, head.firstChild);\n  });\n  // Inject a vertical label that shows when collapsed\n  document.querySelectorAll('.notif-panel').forEach(p => {\n    if (p.querySelector('.notif-panel-vert')) return;\n    const v = document.createElement('div');\n    v.className = 'notif-panel-vert';\n    const t = p.querySelector('.notif-panel-title');\n    v.textContent = t ? t.textContent : 'Log';\n    p.appendChild(v);\n  });\n}\n\nfunction toggleNotifPanel() {\n  const collapsed = !document.body.classList.contains('notif-collapsed');\n  document.body.classList.toggle('notif-collapsed', collapsed);\n  document.querySelectorAll('.notif-panel').forEach(p => p.classList.toggle('collapsed', collapsed));\n  document.querySelectorAll('.sidecar-notif-host').forEach(h => h.classList.toggle('collapsed', collapsed));\n  try { localStorage.setItem('notifCollapsed', collapsed ? '1' : '0'); } catch(e) {}\n}\n\n/* ─── Canonical Timeline/Updates side nav — identical for every role ─── */\nfunction navSeen(btn) {\n  const card = btn.closest('.notif-card');\n  if (!card) return;\n  card.classList.remove('unread');\n  card.classList.add('seen');\n  const dot = card.querySelector('.notif-unread-dot');\n  if (dot) dot.remove();\n  btn.outerHTML = '<div class=\"notif-seen\">✓ seen<\u002Fdiv>';\n  // Decrement the unread badge in this panel\n  const panel = card.closest('.notif-panel');\n  const badge = panel && panel.querySelector('.snav-unread');\n  if (badge) {\n    let n = parseInt(badge.textContent, 10) || 0;\n    n = Math.max(0, n - 1);\n    badge.textContent = n > 0 ? n + ' new' : '—';\n  }\n}\nconst SIDE_NAV_INNER = `\n    <div class=\"snav-tabs\">\n      <button class=\"snav-tab active\" data-pane=\"timeline\" onclick=\"snavTab(this)\">Timeline<\u002Fbutton>\n      <button class=\"snav-tab\" data-pane=\"updates\" onclick=\"snavTab(this)\">Updates <span class=\"notif-unread-badge snav-unread\">2 new<\u002Fspan><\u002Fbutton>\n      <button class=\"snav-collapse\" onclick=\"toggleNotifPanel()\" title=\"Collapse panel\" aria-label=\"Collapse panel\"><svg viewBox=\"0 0 12 12\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"7,3 3,6 7,9\"><\u002Fpolyline><\u002Fsvg><\u002Fbutton>\n    <\u002Fdiv>\n    <div class=\"snav-body\">\n      <div class=\"snav-pane\" data-pane=\"timeline\">\n        <div class=\"vtl-statusbar\">\n          <span class=\"vtl-now\">Now <b class=\"mtl-now-time\">14:24<\u002Fb><\u002Fspan>\n          <span class=\"mtl-status behind\"><span class=\"st-dot\"><\u002Fspan><span class=\"mtl-status-text\">3 min behind<\u002Fspan><\u002Fspan>\n        <\u002Fdiv>\n        <div class=\"vtl\"><\u002Fdiv>\n        <button class=\"vtl-full-btn\" onclick=\"openTtpModal()\"><svg viewBox=\"0 0 14 14\" width=\"12\" height=\"12\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><rect x=\"1.5\"