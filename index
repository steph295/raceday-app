calModal').classList.add('open'); }\nfunction closeCalendar() { const m = document.getElementById('calModal'); if (m) m.classList.remove('open'); }\nfunction calShiftMonth(d) { calMonth += d; if (calMonth < 0) { calMonth = 11; calYear--; } if (calMonth > 11) { calMonth = 0; calYear++; } renderCalendar(); }\nfunction _iso(y, m, d) { return y + '-' + String(m + 1).padStart(2, '0') + '-' + String(d).padStart(2, '0'); }\nfunction renderCalendar() {\n  const grid = document.getElementById('calGrid');\n  if (!grid) return;\n  document.getElementById('calMonthLabel').textContent = CAL_MONTHS[calMonth] + ' ' + calYear;\n  const first = new Date(calYear, calMonth, 1);\n  let lead = (first.getDay() + 6) % 7; // Monday-first\n  const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();\n  const prevDays = new Date(calYear, calMonth, 0).getDate();\n  let html = '';\n  // leading days from previous month\n  for (let i = lead - 1; i >= 0; i--) html += '<div class=\"cal-cell muted\"><div class=\"cal-daynum\">' + (prevDays - i) + '<\u002Fdiv><\u002Fdiv>';\n  for (let d = 1; d <= daysInMonth; d++) {\n    const iso = _iso(calYear, calMonth, d);\n    const evs = calEvents[iso] || [];\n    const isToday = iso === CAL_TODAY;\n    let cell = '<div class=\"cal-cell' + (isToday ? ' today' : '') + '\"><div class=\"cal-daynum\">' + d + '<\u002Fdiv>';\n    const shown = evs.slice(0, 3);\n    shown.forEach(ev => {\n      cell += '<div class=\"cal-ev ' + ev.t + '\" title=\"' + (ev.time ? ev.time + ' · ' : '') + ev.label.replace(/\"/g, '') + '\">' +\n                (ev.time ? '<span class=\"cal-ev-time\">' + ev.time + '<\u002Fspan>' : '') + ev.label + '<\u002Fdiv>';\n    });\n    if (evs.length > 3) cell += '<div class=\"cal-ev more\">+' + (evs.length - 3) + ' more<\u002Fdiv>';\n    cell += '<\u002Fdiv>';\n    html += cell;\n  }\n  // trailing days to complete the last week row\n  const total = lead + daysInMonth;\n  const trail = (7 - (total % 7)) % 7;\n  for (let i = 1; i <= trail; i++