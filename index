  font-size: 11px; color: var(--text-muted);\n}\n.hist-footer .hist-link {\n  color: var(--navy); font-weight: 600; cursor: pointer;\n  background: var(--white); border: 1px solid var(--border);\n  padding: 4px 11px; border-radius: 4px;\n  font-family: var(--sans);\n  transition: background 0.1s;\n}\n.hist-footer .hist-link:hover { background: var(--blue-light); border-color: var(--blue); color: var(--blue); }\n\n/* ── Day-sheet (race-card) SP markers + history (paper-card convention) ── */\n/* Sits in its own trailing column added at runtime */\n.sds-race .ds-body > div { position: relative; }\n.sds-race .ds-body > div.sds-row-head,\n.sds-race .ds-body > div.sds-clean-foot { position: static; }\n\n.sds-sp-cell {\n  display: flex; flex-direction: column;\n  align-items: flex-end; justify-content: flex-start;\n  gap: 5px; padding-top: 4px; padding-right: 4px;\n  min-width: 0;\n}\n.sds-sp-mark {\n  font-family: var(--mono); font-weight: 700;\n  font-size: 16px; line-height: 1;\n  color: var(--text-muted);\n  letter-spacing: -0.01em;\n  display: inline-flex; align-items: baseline; gap: 4px;\n  white-space: nowrap;\n}\n.sds-sp-mark.top { color: var(--red); }\n.sds-sp-mark .sds-sp-label {\n  font-size: 9px; font-weight: 600;\n  letter-spacing: 0.06em; text-transform: uppercase;\n  color: var(--text-muted);\n  opacity: 0.7;\n}\n.sds-sp-mark.stale { color: var(--amber) !important; }\n.sds-sp-mark.stale .sds-sp-num { text-decoration: line-through dotted; text-decoration-color: rgba(176,94,0,0.4); }\n\n.sds-hist-pill {\n  font-family: var(--mono); font-size: 10px; font-weight: 600;\n  padding: 2px 7px;\n  background: var(--white);\n  border: 1px solid var(--border);\n  color: var(--text-muted);\n  border-radius: 4px;\n  cursor: pointer;\n  letter-spacing: 0.02em;\n  display: inline-flex; align-items: center; gap: 4px;\n  transition: background 0.1s, border-color 0.1s, color 0.1s;\n}\n.sds-hist-pill:hover { background: var(--blue-light); color: var(--blue); border-color: rgba