 font-weight: 700;\n  letter-spacing: 0.1em;\n  text-transform: uppercase;\n  color: var(--text-muted);\n  background: var(--bg);\n  border-bottom: 1px solid var(--border);\n}\n.tb-menu-item {\n  padding: 9px 12px;\n  font-size: 12px;\n  cursor: pointer;\n  border-bottom: 1px solid var(--border);\n  display: flex; align-items: center; gap: 8px;\n  color: var(--text);\n  transition: background 0.1s;\n}\n.tb-menu-item:last-child { border-bottom: none; }\n.tb-menu-item:hover { background: var(--blue-light); }\n.tb-menu-item.active { background: var(--blue-light); color: var(--blue); font-weight: 600; }\n.tb-menu-item .tm-meta { font-family: var(--mono); font-size: 10px; color: var(--text-muted); margin-left: auto; }\n.tb-menu-item.active .tm-meta { color: var(--blue); }\n.tb-menu-item .tm-check { color: var(--green-mid); font-weight: 700; margin-left: auto; }\n.tb-menu-item .tm-desc { font-size: 10px; color: var(--text-muted); margin-top: 2px; font-family: var(--mono); letter-spacing: 0.04em; text-transform: uppercase; }\n.tb-menu-item .tm-icon { display: none !important; }\n.tb-menu-item.steward .tm-icon { background: var(--amber-light); color: var(--amber); }\n.tb-menu-item .tm-body { flex: 1; min-width: 0; }\n.tb-menu-item .tm-body .tm-name { font-weight: 600; font-size: 12px; }\n.topbar-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }\n.topbar-going { font-family: var(--mono); font-size: 11px; color: rgba(255,255,255,0.55); background: rgba(255,255,255,0.07); padding: 5px 10px; border-radius: 4px; border: 1px solid rgba(255,255,255,0.12); white-space: nowrap; }\n.going-val { color: #6db3e8; font-weight: 600; }\n.topbar-btn { padding: 6px 14px; border: 1px solid rgba(255,255,255,0.25); border-radius: 5px; background: transparent; color: white; font-size: 12px; font-weight: 500; cursor: pointer; font-family: var(--sans); }\n.topbar-btn.demo { border-color: rgba(100,181,246,0.5); color: #64b5f6; }\n\n/* demo dropdown */\n.demo-wrap { position: relative; }\n.demo-menu { position: absolute; top: calc(100% + 4px); right: 0; background: var(--white); border: 1px solid var(--border); border-radius: 6px; box-shadow: var(--shadow-md); min-width: 210px; z-index: 200; display: none; overflow: hidden; }\n.demo-menu.open { display: block; }\n.demo-menu-label { padding: 7px 12px; font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); font-family: var(--mono); border-bottom: 1px solid var(--border); background: var(--bg); }\n.demo-menu-item { padding: 9px 12px; font-size: 12px; cursor: pointer; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 8px; transition: background 0.1s; }\n.demo-menu-item:last-child { border-bottom: none; }\n.demo-menu-item:hover { background: var(--blue-light); }\n.demo-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }\n.demo-dot.amber { background: var(--amber); }\n.demo-dot.green { background: var(--green-mid); }\n.demo-dot.red { background: var(--red); }\n.demo-dot.blue { background: var(--blue); }\n\n/* ══════════════════════════════════════\n   MAIN LAYOUT\n   Left: notification log (260px, sticky full height)\n   Right: race tabs + scrollable content\n══════════════════════════════════════ */\n.app-body {\n  display: flex;\n  height: calc(100vh - var(--banner-h) - var(--topbar-h));\n  overflow: hidden;\n}\n\n/* ── LEFT: Notification log ── */\n.notif-panel {\n  width: 260px;\n  flex-shrink: 0;\n  background: var(--white);\n  border-right: 1px solid var(--border);\n  display: flex;\n  flex-direction: column;\n  overflow: hidden;\n}\n.notif-panel-head {\n  background: var(--navy);\n  padding: 12px 14px;\n  display: flex; align-items: center; justify-content: space-between;\n  flex-shrink: 0;\n}\n.notif-panel-title { font-size: 11px; font-weight: 600; color: white; letter-spacing: 0.08em; text-transform: uppercase; font-family: var(--mono); }\n.notif-unread-badge { background: var(--amber); color: white; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 10px; font-family: var(--mono); }\n\n.notif-scroll { overflow-y: auto; flex: 1; }\n\n/* ── Side-nav tabs (Timeline / Updates) ── */\n.snav-tabs { display: flex; flex-shrink: 0; background: var(--navy-dark); padding: 0 6px; gap: 2px; }\n.snav-tab {\n  flex: 1; background: none; border: none; cursor: pointer;\n  font-family: var(--mono); font-size: 10.5px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;\n  color: rgba(255,255,255,0.5); padding: 10px 4px 9px;\n  border-bottom: 2px solid transparent; transition: color 0.12s, border-color 0.12s;\n  display: inline-flex; align-items: center; justify-content: center; gap: 6px;\n}\n.snav-tab:hover { color: rgba(255,255,255,0.8); }\n.snav-tab.active { color: #fff; border-bottom-color: var(--amber); }\n.snav-tab .notif-unread-badge { padding: 1px 6px; font-size: 9px; }\n.snav-body { flex: 1; display: flex; flex-direction: column; min-height: 0; }\n.snav-pane { flex: 1; display: flex; flex-direction: column; min-height: 0; }\n\n/* ── Vertical race timeline (in side nav) ── */\n.vtl-statusbar { flex-shrink: 0; padding: 11px 14px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 10px; flex-wrap: wrap; background: #fafbfc; }\n.vtl-now { font-size: 11px; color: var(--text-muted); font-family: var(--mono); }\n.vtl-now b { color: var(--text); font-weight: 700; }\n.vtl { overflow-y: auto; flex: 1; padding: 16px 14px 14px 16px; }\n.vtl-item { position: relative; padding-left: 28px; padding-bottom: 18px; cursor: pointer; }\n.vtl-item:last-child { padding-bottom: 2px; }\n.vtl-item::before { content: ''; position: absolute; left: 9px; top: 18px; bottom: -2px; width: 2px; background: var(--border); }\n.vtl-item:last-child::before { display: none; }\n.vtl-item.done::before, .vtl-item.live::before { background: #2ea160; }\n.vtl-node {\n  position: absolute; left: 0; top: 0; width: 20px; height: 20px; border-radius: 50%;\n  background: var(--white); border: 3px solid var(--border);\n  display: flex; align-items: center; justify-content: center;\n  font-size: 9px; font-weight: 800; font-family: var(--mono); color: var(--text-muted); z-index: 2;\n}\n.vtl-item.done   .vtl-node { background: #2ea160; border-color: #2ea160; color: #fff; }\n.vtl-item.live   .vtl-node { background: var(--white); border-color: #d98a00; color: #9a5300; box-shadow: 0 0 0 4px rgba(217,138,0,0.18); animation: mtlPulse 1.8s ease-in-out infinite; }\n.vtl-item.next   .vtl-node { border-color: var(--navy); color: var(--navy); }\n.vtl-rno { font-size: 8.5px; font-weight: 700; font-family: var(--mono); color: var(--text-muted); letter-spacing: 0.06em; text-transform: uppercase; line-height: 1; margin-bottom: 2px; }\n.vtl-off { font-size: 14px; font-weight: 700; font-family: var(--mono); color: var(--text); line-height: 1.1; }\n.vtl-item.upcoming .vtl-off, .vtl-item.next .vtl-off { color: var(--text-muted); }\n.vtl-meta { font-size: 10px; font-family: var(--mono); margin-top: 2px; }\n.vtl-item.active .vtl-node { outline: 2px solid var(--navy); outline-offset: 2px; }\n.vtl-item.active .vtl-off { text-decoration: underline; text-underline-offset: 2px; }\n.vtl-delay { color: #9a5300; font-weight: 700; }\n.vtl-delay.big { color: var(--red); }\n.vtl-ok { color: #1f7a44; font-weight: 600; }\n.vtl-next-lbl { color: var(--navy); font-weight: 700; }\n/* Collapse: hide the body + tab labels, keep the toggle button visible */\n.snav-collapse {\n  flex: 0 0 auto; align-self: center; width: 28px; height: 28px; margin-left: 2px;\n  background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.15);\n  border-radius: 5px; color: rgba(255,255,255,0.7); cursor: pointer;\n  display: flex; align-items: center; justify-content: center; transition: all 0.12s;\n}\n.snav-collapse:hover { background: rgba(255,255,255,0.16); color: #fff; border-color: rgba(255,255,255,0.3); }\n.snav-collapse svg { width: 11px; height