opPropagation();toast('Patrol footage requested','blue')\">Request Patrol Footage<\u002Fbutton>\n        <button class=\"cd-cta\" onclick=\"event.stopPropagation();toast('Reported to stewards','amber')\">Flag to Stewards<\u002Fbutton>\n      <\u002Fdiv>\n    <\u002Fdiv>\n    <div>\n      <div style=\"padding:11px 13px;background:${toneBg};border:1px solid rgba(0,0,0,0.06);border-left:3px solid ${toneCol};border-radius:6px;font-size:12px;line-height:1.5;color:var(--text);\">\n        ${_esc(d.note)}\n      <\u002Fdiv>\n      <div class=\"cd-stats\" style=\"margin-top:10px;\">\n        <div class=\"cd-stat\"><span class=\"k\">Stall<\u002Fspan><span class=\"v big\">${_esc(d.stall)}<\u002Fspan><\u002Fdiv>\n        <div class=\"cd-stat\"><span class=\"k\">Behaviour<\u002Fspan><span class=\"v\">${_esc(d.behaviour)}<\u002Fspan><\u002Fdiv>\n        <div class=\"cd-stat\" style=\"grid-column:span 2;\"><span class=\"k\">Veterinary<\u002Fspan><span class=\"v\">${_esc(d.vet)}<\u002Fspan><\u002Fdiv>\n      <\u002Fdiv>\n      ${flagsHtml ? `<div style=\"margin-top:10px;\">${flagsHtml}<\u002Fdiv>` : ''}\n    <\u002Fdiv>`;\n}\n\n/* Extend toggleConnDrawer to handle starter */\nconst _origToggleConn = toggleConnDrawer;\ntoggleConnDrawer = function(rowNo, type, evt) {\n  if (type !== 'starter') return _origToggleConn(rowNo, type, evt);\n  if (evt) evt.stopPropagation();\n  const drawer = document.getElementById('cd-' + rowNo);\n  if (!drawer) return;\n  const sameLink = connOpen && connOpen.rowNo === rowNo && connOpen.type === type;\n  closeAllConnDrawers();\n  if (sameLink) { connOpen = null; return; }\n  const data = starterData[rowNo];\n  if (!data) return;\n  drawer.innerHTML = `<button class=\"stew-drawer-close\" onclick=\"event.stopPropagation();toggleConnDrawer(${rowNo},'starter',event)\" aria-label=\"Close\">✕<\u002Fbutton><div class=\"stew-drawer-inner\">${renderStarter(data, rowNo)}<\u002Fdiv>`;\n  drawer.classList.add('open');\n  const row = drawer.previousElementSibling;\