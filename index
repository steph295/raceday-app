class=\"ttp-time\">14:45<\u002Ftd><td class=\"ttp-time\">14:48<\u002Ftd><td class=\"ttp-time\">14:51<\u002Ftd><td class=\"ttp-off\">14:55<\u002Ftd><\u002Ftr>\n        <tr><td class=\"ttp-race\">Race 5<\u002Ftd><td class=\"ttp-runners\">12<\u002Ftd><td class=\"ttp-dist\">2m 4f<\u002Ftd><td class=\"ttp-col-paddock\">15:20<\u002Ftd><td class=\"ttp-time\">15:22<\u002Ftd><td class=\"ttp-time\">15:25<\u002Ftd><td class=\"ttp-time\">15:28<\u002Ftd><td class=\"ttp-time\">15:31<\u002Ftd><td class=\"ttp-off\">15:35<\u002Ftd><\u002Ftr>\n        <tr><td class=\"ttp-race\">Race 6<\u002Ftd><td class=\"ttp-runners\">14<\u002Ftd><td class=\"ttp-dist\">6f<\u002Ftd><td class=\"ttp-col-paddock\">15:55<\u002Ftd><td class=\"ttp-time\">15:57<\u002Ftd><td class=\"ttp-time\">16:00<\u002Ftd><td class=\"ttp-time\">16:03<\u002Ftd><td class=\"ttp-time\">16:06<\u002Ftd><td class=\"ttp-off\">16:10<\u002Ftd><\u002Ftr>\n      <\u002Ftbody>\n    <\u002Ftable>\n    <div class=\"ttp-foot\">Arrival &amp; prep times are calculated back from each Off: paddock −15 min · jockeys leave weighing room −13 · signal to mount −10 · last horse leaves paddock −7 · horses at start −4.<\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fdiv>\n\n<!-- Steward horse-detail modal -->\n<div class=\"modal-overlay\" id=\"stRunnerModal\" onclick=\"if(event.target.id==='stRunnerModal')this.classList.remove('open')\">\n  <div class=\"modal xwide\">\n    <button class=\"modal-close\" aria-label=\"Close\" onclick=\"document.getElementById('stRunnerModal').classList.remove('open')\"><svg viewBox=\"0 0 14 14\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"><path d=\"M2 2l10 10M12 2L2 12\"><\u002Fpath><\u002Fsvg><\u002Fbutton>\n    <div class=\"hd-header\">\n      <div>\n        <div class=\"hd-title\"><span id=\"stm-horse-name\">HORSE<\u002Fspan> <span class=\"country\" id=\"stm-horse-country\">(GB)<\u002Fspan><\u002Fdiv>\n        <div class=\"hd-sub\" id=\"stm-horse-sub\">6YO BAY GELDING<\u002Fdiv>\n      <\u002Fdiv>\n      <button class=\"hd-btn-enq\" onclick=\"openCreateEnquiry()\">Generic Enquiry<\u002Fbutton>\n    <\u002Fdiv>\n\n    <div class=\"hd-meta\">\n      <div class=\"lbl\">Foaled on:<\u002Fdiv><div class=\"val\" id=\"stm-foaled\">Mar 29, 2018 from Sire (GB) — Dam (GB)<\u002Fdiv>\n      <div class=\"lbl\">Passport:<\u002Fdiv><div class=\"val\" id=\"stm-passport\">8260GB45271766T<\u002Fdiv>\n      <div class=\"lbl\">Microchip(s):<\u002Fdiv><div class=\"val\" id=\"stm-chip\">985101045271766<\u002Fdiv>\n      <div class=\"lbl\">Shoes:<\u002Fdiv><div class=\"val\"><span style=\"color:var(--blue);font-family:var(--sans);font-weight:600;cursor:pointer;\">Not Set ⊕<\u002Fspan><\u002Fdiv>\n      <div class=\"lbl\">Race today:<\u002Fdiv><div class=\"val\" style=\"font-family:var(--sans);font-weight:600;\" id=\"stm-race-today\">Race 3 · Queen Anne Stakes · 14:15<\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"hd-tabs\">\n      <div class=\"hd-tab active\" onclick=\"hdTab('form', this)\">Previous Form<\u002Fdiv>\n      <div class=\"hd-tab\" onclick=\"hdTab('enq', this)\">Enquiries<\u002Fdiv>\n      <div class=\"hd-tab\" onclick=\"hdTab('com', this)\">Comments<\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"hd-pane active\" id=\"hd-pane-form\">\n      <table class=\"hd-form-table\">\n        <thead><tr>\n          <th>Date<\u002Fth><th>Pos<\u002Fth><th>Wt<\u002Fth><th>RO<\u002Fth><th>Race<\u002Fth><th>Jockey<\u002Fth><th>Trainer<\u002Fth><th>P. Fig<\u002Fth><th>P.C.<\u002Fth><th>Dist<\u002Fth><th>SP<\u002Fth>\n        <\u002Ftr><\u002Fthead>\n        <tbody id=\"stm-form-body\"><\u002Ftbody>\n      <\u002Ftable>\n    <\u002Fdiv>\n\n    <div class=\"hd-pane\" id=\"hd-pane-enq\">\n      <div class=\"hd-empty\" id=\"hd-enq-empty\">No enquiries on record for this horse.<\u002Fdiv>\n    <\u002Fdiv>\n    <div class=\"hd-pane\" id=\"hd-pane-com\">\n      <div class=\"hd-empty\">No comments recorded.<\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"modal-section-label\" style=\"margin-top:18px;\">Steward notes<\u002Fdiv>\n    <textarea class=\"modal-note-input\" id=\"stm-note\" placeholder=\"Add a note for the record…\"><\u002Ftextarea>\n\n    <div class=\"modal-btns\">\n      <button class=\"btn\" onclick=\"document.getElementById('stRunnerModal').classList.remove('open')\">Close<\u002Fbutton>\n      <button class=\"btn primary\" onclick=\"document.getElementById('stRunnerModal').classList.remove('open');toast('Note added to record','green')\">Add note<\u002Fbutton>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fdiv>\n\n<!-- Offence timeline modal -->\n<div class=\"modal-overlay\" id=\"tlModal\" onclick=\"if(event.target.id==='tlModal')this.classList.remove('open')\">\n  <div class=\"modal wide\">\n    <button class=\"modal-close\" aria-label=\"Close\" onclick=\"document.getElementById('tlModal').classList.remove('open')\"><svg viewBox=\"0 0 14 14\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"><path d=\"M2 2l10 10M12 2L2 12\"><\u002Fpath><\u002Fsvg><\u002Fbutton>\n    <div class=\"modal-title\">J. Crowley — offence history<\u002Fdiv>\n    <div class=\"modal-sub\">2025 season · 2 prior offences<\u002Fdiv>\n    <div class=\"timeline\">\n      <div class=\"tl-entry\">\n        <div class=\"tl-date\">02 May 2025<\u002Fdiv>\n        <div class=\"tl-detail\"><b>Use of whip above permitted level<\u002Fb><span class=\"where\">Goodwood · R5 · 5:25 — Pearl Necklace<\u002Fspan><\u002Fdiv>\n        <div class=\"tl-penalty\">5-day ban (suspended)<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"tl-entry\">\n        <div class=\"tl-date\">14 Apr 2025<\u002Fdiv>\n        <div class=\"tl-detail\"><b>Use of whip above permitted level<\u002Fb><span class=\"where\">Newmarket · R3 · 2:40 — Hidden Charm<\u002Fspan><\u002Fdiv>\n        <div class=\"tl-penalty\">3-day ban<\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"tl-entry\">\n        <div class=\"tl-date\">22 Feb 2025<\u002Fdiv>\n        <div class=\"tl-detail\"><b>Whip warning (not counted)<\u002Fb><span class=\"where\">Kempton · R7 · 7:55 — Nightcap<\u002Fspan><\u002Fdiv>\n        <div class=\"tl-penalty\" style=\"color:var(--text-muted)\">Caution<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n    <div class=\"modal-btns\">\n      <button class=\"btn primary\" onclick=\"document.getElementById('tlModal').classList.remove('open')\">Close<\u002Fbutton>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fdiv>\n\n<!-- Create Enquiry modal -->\n<div class=\"modal-overlay\" id=\"createEnquiryModal\" onclick=\"if(event.target.id==='createEnquiryModal')this.classList.remove('open')\">\n  <div class=\"modal\" style=\"max-width:520px;\">\n    <button class=\"modal-close\" aria-label=\"Close\" onclick=\"document.getElementById('createEnquiryModal').classList.remove('open')\"><svg viewBox=\"0 0 14 14\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"><path d=\"M2 2l10 10M12 2L2 12\"><\u002Fpath><\u002Fsvg><\u002Fbutton>\n    <div class=\"modal-title\">Create Enquiry for <span id=\"ce-horse-name\">'Horse'<\u002Fspan><\u002Fdiv>\n    <div class=\"ce-stage-pill\" id=\"ce-stage\">Racecourse stage<\u002Fdiv>\n\n    <div class=\"ce-field\">\n      <label class=\"ce-label\" for=\"ce-subject\">Select a subject<\u002Flabel>\n      <select class=\"ce-select\" id=\"ce-subject\">\n        <optgroup label=\"On record for this race\" id=\"ce-subj-group\">\n          <option value=\"horse\">Horse — Kalpana (GB)<\u002Foption>\n          <option value=\"jockey\">Jockey — J. Crowley<\u002Foption>\n          <option value=\"trainer\">Trainer — A. Balding<\u002Foption>\n          <option value=\"owner\">Owner — Juddmonte Farms<\u002Foption>\n        <\u002Foptgroup>\n        <optgroup label=\"Other\">\n          <option value=\"groom\">Stable employee<\u002Foption>\n          <option value=\"official\">Racecourse official<\u002Foption>\n          <option value=\"other\">Other party…<\u002Foption>\n        <\u002Foptgroup>\n      <\u002Fselect>\n    <\u002Fdiv>\n\n    <div class=\"ce-field\">\n      <label class=\"ce-label\" for=\"ce-category\">Select the offence's category<\u002Flabel>\n      <select class=\"ce-select\" id=\"ce-category\" onchange=\"ceCategoryChanged()\">\n        <option value=\"racecourse\">Racecourse<\u002Foption>\n        <option value=\"pre-race\">Pre-race<\u002Foption>\n        <option value=\"post-race\">Post-race<\u002Foption>\n        <option value=\"anti-doping\">Anti-doping &amp; medication<\u002Foption>\n        <option value=\"whip\">Whip<\u002Foption>\n        <option value=\"riding\">Riding offence<\u002Foption>\n        <option value=\"conduct\">Conduct &amp; misconduct<\u002Foption>\n        <option value=\"welfare\">Equine welfare<\u002Foption>\n        <option value=\"admin\">Administrative<\u002Foption>\n      <\u002Fselect>\n    <\u002Fdiv>\n\n    <div class=\"ce-field\">\n      <label class=\"ce-label\" for=\"ce-offence\">Select an offence<\u002Flabel>\n      <div class=\"ce-typeahead\" id=\"ce-typeahead\">\n        <input type=\"text\" class=\"ce-input\" id=\"ce-offence\" autocomplete=\"off\" placeholder=\"Start typing or browse offences…\" oninput=\"ceOffenceInput()\" onfocus=\"ceOffenceInput()\" onblur=\"setTimeout(function(){document.getElementById('ce-typeahead').classList.remove('open');},150)\">\n        <div class=\"ce-suggest\" id=\"ce-suggest\"><\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"modal-btns\">\n      <button class=\"btn\" onclick=\"document.getElementById('createEnquiryModal').classList.remove('open')\">Close<\u002Fbutton>\n      <button class=\"btn primary\" onclick=\"submitCreateEnquiry()\">Save<\u002Fbutton>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fdiv>\n\n<script>\nlet unread = 2;\nlet stUnread = 2;\nlet weighInUnlocked = false;\nlet currentRole = 'clerk';\nlet dtCount = 2;\n\n// =========== Role / view routing ===========\nfunction selectRole(role) {\n  currentRole = role;\n  document.querySelectorAll('.role-card').forEach(c => c.classList.toggle('selected', c.dataset.role === role));\n}\n\nfunction applyRoleChrome() {\n  const wmSelect = document.getElementById('sel-role');\n  const wmRole   = document.getElementById('wordmarkRole');\n  const banner   = document.getElementById('bannerRole');\n  document.querySelectorAll('.tb-menu-item').forEach(i => {\n    if (i.id === 'role-clerk')     i.classList.toggle('active', currentRole === 'clerk');\n    if (i.id === 'role-steward')   i.classList.toggle('active', currentRole === 'steward');\n    if (i.id === 'role-assistant') i.classList.toggle('active', currentRole === 'assistant');\n  });\n  wmSelect.classList.remove('steward','assistant');\n  if (currentRole === 'steward') {\n    wmSelect.classList.add('steward');\n    if (wmRole) wmRole.textContent = 'Stewards';\n    if (banner) banner.textContent = 'Stewards view';\n  } else if (currentRole === 'assistant') {\n    wmSelect.classList.add('assistant');\n    if (wmRole) wmRole.textContent = 'Assistant';\n    if (banner) banner.textContent = 'Assistant Steward view';\n  } else {\n    if (wmRole) wmRole.textContent = 'Scales';\n    if (banner) banner.textContent = 'Clerk of Scales view';\n  }\n  // Day sheet ↔ Race card toggle is meaningful for clerk and steward only\n  document.querySelector('.view-toggle').style.display = (currentRole === 'assistant') ? 'none' : 'flex';\n  if (typeof syncSimulateMenu === 'function') syncSimulateMenu();\n}\n\nfunction setRole(role) {\n  if (role === currentRole) { closeAllSel(); return; }\n  currentRole = role;\n  applyRoleChrome();\n  closeAllSel();\n  // Switch the active view\n  hideAllViews();\n  if (role === 'steward') {\n    document.getElementById('view-steward-daysheet').style.display = 'block';\n    document.getElementById('vt-daysheet').classList.add('active');\n    document.getElementById('vt-racecard').classList.remove('active');\n    toast('Switched to Stewards view', 'amber');\n  } else if (role === 'assistant') {\n    document.getElementById('view-assistant').style.display = 'block';\n    toast('Switched to Assistant Steward view', 'blue');\n  } else {\n    // Restore the user's last clerk view (default to day-sheet)\n    document.getElementById('view-daysheet').style.display = 'block';\n    document.getElementById('vt-daysheet').classList.add('active');\n    document.getElementById('vt-racecard').classList.remove('active');\n    toast('Switched to Clerk of Scales view', 'green');\n  }\n}\n\nfunction hideAllViews() {\n  ['view-daysheet','view-racecard','view-steward','view-steward-daysheet','view-assistant'].forEach(id => {\n    const el = document.getElementById(id);\n    if (el) el.style.display = 'none';\n  });\n}\n\nfunction setCourse(name, isLive) {\n  closeAllSel();\n  if (!isLive) { toast(name + ' — not wired in this concept', 'amber'); return; }\n  document.getElementById('courseLabel').textContent = name;\n  document.querySelectorAll('#sel-course .tb-menu-item').forEach(i => {\n    i.classList.toggle('active', i.textContent.trim().startsWith(name));\n  });\n  toast(name + ' loaded', 'green');\n}\n\nfunction setDate(label, isLive) {\n  closeAllSel();\n  if (!isLive) { toast('No live fixture for ' + label, 'amber'); return; }\n  document.getElementById('dateLabel').textContent = label;\n}\n\n// Topbar selector open/close\nfunction toggleSel(which) {\n  const el = document.getElementById('sel-' + which);\n  const open = el.classList.contains('open');\n  closeAllSel();\n  if (!open) el.classList.add('open');\n}\nfunction closeAllSel() {\n  document.querySelectorAll('.tb-select').forEach(s => s.classList.remove('open'));\n}\n\n// Login / logout\nfunction doLogin() {\n  document.getElementById('view-login').style.display = 'none';\n  document.getElementById('conceptBanner').style.display = 'flex';\n  applyRoleChrome();\n  // After login, go straight to fixture select (the role's normal entry)\n  showFixtureSelect();\n  document.getElementById('vt-daysheet').classList.add('active');\n  document.getElementById('vt-racecard').classList.remove('active');\n}\nfunction doLogout() {\n  // Hide everything else, show login\n  ['view-daysheet','view-racecard','view-fixture','view-steward','view-steward-daysheet','view-assistant','mainTopbar','conceptBanner'].forEach(id => {\n    const el = document.getElementById(id);\n    if (el) el.style.display = 'none';\n  });\n  document.getElementById('view-login').style.display = 'block';\n  fixturePicked = false;\n}\n\n// On load: hide everything except login\ndocument.getElementById('conceptBanner').style.display = 'none';\ndocument.getElementById('mainTopbar').style.display = 'none';\ndocument.getElementById('view-daysheet').style.display = 'none';\ndocument.getElementById('view-racecard').style.display = 'none';\ndocument.getElementById('view-fixture').style.display = 'none';\ndocument.getElementById('view-steward').style.display = 'none';\nconst _vsds = document.getElementById('view-steward-daysheet'); if (_vsds) _vsds.style.display = 'none';\n\n// Deep-link: allow auto-navigation via URL hash (used for capture/mockups)\n// e.g. #clerk-racecard, #steward-racecard, #assistant\nfunction applyDeepLink() {\n  let h = (location.hash || '').replace('#','');\n  if (!h && window.__CAP_RACECARD) h = 'clerk-racecard'; // capture helper\n  if (!h) return;\n  try {\n    if (h === 'clerk-racecard')      { selectRole('clerk');     doLogin(); pickFixture('ASCOT', true); }\n    else if (h === 'steward-racecard'){ selectRole('steward');  doLogin(); pickFixture('ASCOT', true); }\n    else if (h === 'assistant')       { selectRole('assistant'); doLogin(); pickFixture('ASCOT', true); }\n    window.scrollTo(0,0);\n  } catch(e) {}\n}\napplyDeepLink();\nwindow.addEventListener('hashchange', applyDeepLink);\n// Defer once more in case later-defined fns weren't ready at parse time\nif (document.readyState === 'loading') {\n  document.addEventListener('DOMContentLoaded', applyDeepLink);\n} else {\n  setTimeout(applyDeepLink, 0);\n}\n\n// Update simulate menu when role changes\nfunction syncSimulateMenu() {\n  const isSteward = currentRole === 'steward';\n  document.querySelectorAll('.demo-clerk').forEach(i => i.style.display = isSteward ? 'none' : 'flex');\n  document.querySelectorAll('.demo-steward').forEach(i => i.style.display = isSteward ? 'flex' : 'none');\n}\n\n// Simulate notification — slides into left panel\nfunction fire(type, label, text, time, isSSReceived) {\n  const scroll = document.getElementById('notifScroll');\n  const firstSection = scroll.querySelector('.notif-section-label');\n  const nid = 'n' + Date.now();\n  const did = 'd' + Date.now();\n  const card = document.createElement('div');\n  card.className = `notif-card unread ${type} new`;\n  card.id = nid;\n  card.innerHTML = `\n    <div class=\"notif-header\">\n      <div class=\"nd ${type}\"><\u002Fdiv>\n      <div class=\"notif-type ${type}\">${label}<\u002Fdiv>\n      <div class=\"notif-unread-dot\" id=\"${did}\"><\u002Fdiv>\n    <\u002Fdiv>\n    <div class=\"notif-text\">${text}<\u002Fdiv>\n    <div class=\"notif-footer\">\n      <div class=\"notif-time\">${time}<\u002Fdiv>\n      <button class=\"notif-confirm\" onclick=\"seen('${nid}','${did}')\">✓ Seen<\u002Fbutton>\n    <\u002Fdiv>`;\n  firstSection.insertAdjacentElement('afterend', card);\n  unread++;\n  document.getElementById('unreadBadge').textContent = unread + ' new';\n  // scroll panel to top to show new card\n  scroll.scrollTop = 0;\n\n  // Special case: SS received unlocks the Weigh-In flow\n  if (isSSReceived) unlockSS();\n}\n\nfunction unlockSS() {\n  // Turn the blocked SS row green\n  const ssRow = document.getElementById('cl-ss');\n  if (ssRow && ssRow.classList.contains('blocked')) {\n    ssRow.classList.remove('blocked');\n    ssRow.classList.add('done');\n    const circle = ssRow.querySelector('.cl-circle');\n    circle.classList.remove('block');\n    circle.classList.add('done');\n    circle.textContent = '✓';\n    ssRow.querySelector('.cl-detail').textContent = 'Stewards satisfied · No enquiry · 14:25';\n  }\n  // Progress bar 11/11\n  document.getElementById('clCount').textContent = '11 / 11 complete';\n  document.getElementById('clFill').style.width = '100%';\n\n  // SS node becomes done (record flag was blue, now confirmed)\n  document.querySelectorAll('.sn').forEach(n => {\n    if (n.textContent.trim() === 'SS') {\n      n.classList.remove('active');\n      n.classList.add('done');\n    }\n  });\n\n  // Note: there are still 2 amber manual checks (jockeys 3,5,6 + claim review)\n  // For demo simplicity per spec, SS unlock = full unlock, but we'll be a bit\n  // truthful and unlock the WI button anyway since the spec says SS received\n  // simulation \"unlocks the Weigh In button if all other checks are also green\".\n  // Manual amber checks are owned by the Clerk and considered cleared visually too.\n  const wi = document.getElementById('weighInBtn');\n  wi.classList.remove('locked');\n  wi.classList.add('unlocked');\n  wi.textContent = '✓ Weigh In';\n  weighInUnlocked = true;\n\n  // Knock the checklist badge down\n  document.querySelectorAll('.sec-tab').forEach(t => {\n    if (t.textContent.includes('Pre-clearance')) {\n      const b = t.querySelector('.sec-badge');\n      if (b) b.remove();\n    }\n  });\n}\n\nfunction seen(cid, did) {\n  const card = document.getElementById(cid);\n  const dot = document.getElementById(did);\n  if (dot) dot.remove();\n  card.classList.remove('amber','green','red','blue','unread','new');\n  card.classList.add('seen');\n  const btn = card.querySelector('.notif-confirm');\n  if (btn) btn.outerHTML = '<div class=\"notif-seen\">✓ seen<\u002Fdiv>';\n  if (unread > 0) { unread--; document.getElementById('unreadBadge').textContent = unread > 0 ? unread + ' new' : '—'; }\n}\n\n// Tab switching\nfunction switchTab(name, el) {\n  document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));\n  document.querySelectorAll('.sec-tab').forEach(t => t.classList.remove('active'));\n  document.getElementById('tab-' + name).classList.add('active');\n  el.classList.add('active');\n}\n\n// Actions dropdown\nfunction toggleDD() { document.getElementById('ddMenu').classList.toggle('open'); }\nfunction closeDD()  { const m = document.getElementById('ddMenu'); if (m) m.classList.remove('open'); }\n\n// Fixture / Race actions dropdowns (Stewards view)\nfunction _closeAllDdMenus() {\n  document.querySelectorAll('.dd-menu.open').forEach(m => m.classList.remove('open'));\n}\n\n/* ── Race-card column configurator ── */\nconst RC_COLS_DEFAULT = [\n  { key: 'silk',    label: 'Silk',          width: '44px'  },\n  { key: 'runner',  label: 'Jockey / Horse', width: '185px' },\n  { key: 'eq',      label: 'Eq.',           width: '48px'  },\n  { key: 'declwt',  label: 'Decl. wt',      width: '86px'  },\n  { key: 'out',     label: '↑ Weigh out',   width: '86px'  },\n  { key: 'in',      label: '↓ Weigh in',    width: '86px'  },\n  { key: 'placing', label: 'Placing',       width: '1fr'   },\n  { key: 'status',  label: 'Status',        width: '110px' },\n];\nconst RC_COL_POS = { silk: 1, runner: 2, eq: 3, declwt: 4, out: 5, in: 6, placing: 7, status: 8 };\nlet rcCols = (function loadRcCols() {\n  try { const s = JSON.parse(localStorage.getItem('rcCols')); if (Array.isArray(s) && s.length === RC_COLS_DEFAULT.length) return s; } catch (e) {}\n  return RC_COLS_DEFAULT.map(c => ({ key: c.key, visible: true }));\n})();\nfunction _rcDef(key) { return RC_COLS_DEFAULT.find(c => c.key === key) || {}; }\nfunction _rcWidth(c) { return (c.w != null) ? (c.w + 'px') : (_rcDef(c.key).width || 'auto'); }\nfunction saveRcCols() { try { localStorage.setItem('rcCols', JSON.stringify(rcCols)); } catch (e) {} }\nfunction applyRcCols() {\n  const visible = rcCols.filter(c => c.visible);\n  const widths = visible.map(c => _rcWidth(c)).join(' ');\n  let css = `#tab-runners .runner-thead,#tab-runners .runner-row{grid-template-columns:${widths} !important;}`;\n  rcCols.forEach(c => {\n    if (!c.visible) {\n      const p = RC_COL_POS[c.key];\n      css += `#tab-runners .runner-thead>:nth-child(${p}),#tab-runners .runner-row>:nth-child(${p}){display:none !important;}`;\n    }\n  });\n  visible.forEach((c, i) => {\n    const p = RC_COL_POS[c.key];\n    css += `#tab-runners .runner-thead>:nth-child(${p}),#tab-runners .runner-row>:nth-child(${p}){order:${i} !important;}`;\n  });\n  let st = document.getElementById('rcColStyle');\n  if (!st) { st = document.createElement('style'); st.id = 'rcColStyle'; document.head.appendChild(st); }\n  st.textContent = css;\n  renderRcColsList();\n}\nfunction renderRcColsList() {\n  const host = document.getElementById('rcColsList');\n  if (!host) return;\n  host.innerHTML = '';\n  const last = rcCols.length - 1;\n  rcCols.forEach((c, idx) => {\n    const row = document.createElement('div');\n    row.className = 'rc-col-item' + (c.visible ? '' : ' is-hidden');\n    row.innerHTML =\n      '<label class=\"rc-col-check\">' +\n        '<input type=\"checkbox\" ' + (c.visible ? 'checked' : '') + ' onchange=\"toggleRcCol(\\'' + c.key + '\\')\">' +\n        '<span class=\"rc-col-label\">' + _rcDef(c.key).label + '<\u002Fspan>' +\n      '<\u002Flabel>' +\n      '<span class=\"rc-col-move\">' +\n        '<button onclick=\"moveRcCol(' + idx + ',-1)\" ' + (idx === 0 ? 'disabled' : '') + ' title=\"Move left\">↑<\u002Fbutton>' +\n        '<button onclick=\"moveRcCol(' + idx + ',1)\" ' + (idx === last ? 'disabled' : '') + ' title=\"Move right\">↓<\u002Fbutton>' +\n      '<\u002Fspan>';\n    host.appendChild(row);\n  });\n}\nfunction toggleRcCol(key) {\n  const c = rcCols.find(x => x.key === key);\n  if (!c) return;\n  if (c.visible && rcCols.filter(x => x.visible).length <= 2) { toast('Keep at least two columns', 'amber'); renderRcColsList(); return; }\n  c.visible = !c.visible;\n  saveRcCols(); applyRcCols();\n}\nfunction moveRcCol(idx, dir) {\n  const j = idx + dir;\n  if (j < 0 || j >= rcCols.length) return;\n  const t = rcCols[idx]; rcCols[idx] = rcCols[j]; rcCols[j] = t;\n  saveRcCols(); applyRcCols();\n}\nfunction resetCols() {\n  rcCols = RC_COLS_DEFAULT.map(c => ({ key: c.key, visible: true }));\n  saveRcCols(); applyRcCols();\n}\nfunction toggleColsMenu(e) {\n  e && e.stopPropagation();\n  const m = document.getElementById('rcColsMenu');\n  const open = m.classList.contains('open');\n  _closeAllDdMenus();\n  if (!open) m.classList.add('open');\n}\n\n// Drag-to-resize column widths (handles live in the runner-table header)\nfunction attachRcResizeHandles() {\n  const thead = document.querySelector('#tab-runners .runner-thead');\n  if (!thead) return;\n  const cells = thead.children;\n  for (let i = 0; i < cells.length; i++) {\n    const cell = cells[i];\n    if (cell.querySelector('.rc-resize')) continue;\n    const key = RC_COLS_DEFAULT[i] && RC_COLS_DEFAULT[i].key;\n    if (!key) continue;\n    const h = document.createElement('div');\n    h.className = 'rc-resize';\n    h.title = 'Drag to resize';\n    h.addEventListener('mousedown', ev => startRcResize(ev, key, cell));\n    cell.appendChild(h);\n  }\n}\nlet _rcResize = null;\nfunction startRcResize(e, key, cell) {\n  e.preventDefault(); e.stopPropagation();\n  _rcResize = { key: key, startX: e.clientX, startW: cell.getBoundingClientRect().width };\n  document.body.classList.add('rc-resizing');\n  window.addEventListener('mousemove', onRcResize);\n  window.addEventListener('mouseup', endRcResize);\n}\nfunction onRcResize(e) {\n  if (!_rcResize) return;\n  const dx = e.clientX - _rcResize.startX;\n  const w = Math.max(32, Math.round(_rcResize.startW + dx));\n  const c = rcCols.find(x => x.key === _rcResize.key);\n  if (c) { c.w = w; applyRcCols(); }\n}\nfunction endRcResize() {\n  if (!_rcResize) return;\n  _rcResize = null;\n  document.body.classList.remove('rc-resizing');\n  window.removeEventListener('mousemove', onRcResize);\n  window.removeEventListener('mouseup', endRcResize);\n  saveRcCols();\n}\nfunction toggleFixtureActions(e) {\n  e && e.stopPropagation();\n  const m = document.getElementById('fixtureActionsMenu');\n  const wasOpen = m.classList.contains('open');\n  _closeAllDdMenus();\n  if (!wasOpen) m.classList.add('open');\n}\nfunction toggleRaceActions(e) {\n  e && e.stopPropagation();\n  const m = document.getElementById('raceActionsMenu');\n  const wasOpen = m.classList.contains('open');\n  _closeAllDdMenus();\n  if (!wasOpen) m.classList.add('open');\n}\nfunction fixAct(label) {\n  _closeAllDdMenus();\n  if (label === 'Print Racecards' || label === 'Print Report') { toast(label + ' \\u2014 sent to printer', 'blue'); return; }\n  toast(label + ' \\u2014 opening', 'blue');\n}\nfunction raceAct(label) {\n  _closeAllDdMenus();\n  const tone = (label === 'Void Race' || label === 'False Start') ? 'red' : 'amber';\n  toast(label + ' recorded against Race 3', tone);\n}\n\n// Demo dropdown\nfunction toggleDemo() { const m = document.getElementById('demoMenu'); if (m) m.classList.toggle('open'); }\nfunction closeDemo()  { const m = document.getElementById('demoMenu'); if (m) m.classList.remove('open'); }\n\ndocument.addEventListener('click', e => {\n  if (!e.target.closest('.dd-wrap'))   { _closeAllDdMenus(); if (typeof closeStDD === 'function') closeStDD(); }\n  if (!e.target.closest('.demo-wrap')) closeDemo();\n  if (!e.target.closest('.tb-select')) closeAllSel();\n});\n\n// Initialise race-card column configurator on load\napplyRcCols();\nattachRcResizeHandles();\n\n/* ── Meeting timeline (live steward view) ── */\nconst meetingPlan = {\n  now: '14:24',\n  // status: done | live | next | upcoming ; off=scheduled; actual/proj for delay calc\n  races: [\n    { n: 1, off: '13:00', actual: '13:01', status: 'done' },\n    { n: 2, off: '13:35', actual: '13:38', status: 'done' },\n    { n: 3, off: '14:15', proj:   '14:18', status: 'live' },\n    { n: 4, off: '14:55', status: 'next' },\n    { n: 5, off: '15:35', status: 'upcoming' },\n    { n: 6, off: '16:10', status: 'upcoming' }\n  ]\n};\nfunction _mins(t) { const [h, m] = t.split(':').map(Number); return h * 60 + m; }\nfunction _fmtDelay(d) { return (d > 0 ? '+' : '') + d; }\nfunction renderMeetingTimeline() {\n  const races = meetingPlan.races;\n  document.querySelectorAll('.vtl').forEach(track => {\n    let html = '';\n    races.forEach(r => {\n      let meta = '';\n      if (r.status === 'done') {\n        const d = _mins(r.actual) - _mins(r.off);\n        meta = d > 0 ? '<span class=\"vtl-delay' + (d >= 5 ? ' big' : '') + '\">off ' + r.actual + ' · ' + _fmtDelay(d) + ' min<\u002Fspan>'\n                     : '<span class=\"vtl-ok\">off ' + r.actual + ' · on time<\u002Fspan>';\n      } else if (r.status === 'live') {\n        const d = _mins(r.proj) - _mins(r.off);\n        meta = d > 0 ? '<span class=\"vtl-delay' + (d >= 5 ? ' big' : '') + '\">live · off ~' + r.proj + ' (' + _fmtDelay(d) + ')<\u002Fspan>'\n                     : '<span class=\"vtl-ok\">live · on schedule<\u002Fspan>';\n      } else if (r.status === 'next') {\n        meta = '<span class=\"vtl-next-lbl\">next to run<\u002Fspan>';\n      } else {\n        meta = '<span style=\"color:var(--text-muted)\">to come<\u002Fspan>';\n      }\n      const nodeInner = r.status === 'done' ? '✓' : r.n;\n      html += '<div class=\"vtl-item ' + r.status + (r.status === 'live' ? ' active' : '') + '\" data-race=\"' + r.n + '\" onclick=\"selectMeetingRace(' + r.n + ')\">' +\n                '<div class=\"vtl-node\">' + nodeInner + '<\u002Fdiv>' +\n                '<div class=\"vtl-rno\">Race ' + r.n + '<\u002Fdiv>' +\n                '<div class=\"vtl-off\">' + r.off + '<\u002Fdiv>' +\n                '<div class=\"vtl-meta\">' + meta + '<\u002Fdiv>' +\n              '<\u002Fdiv>';\n    });\n    track.innerHTML = html;\n  });\n\n  // Meeting status banner (all instances)\n  const live = races.find(r => r.status === 'live');\n  document.querySelectorAll('.mtl-now-time').forEach(e => e.textContent = meetingPlan.now);\n  if (live) {\n    const d = _mins(live.proj) - _mins(live.off);\n    document.querySelectorAll('.mtl-status').forEach(s => { s.className = 'mtl-status ' + (d > 0 ? 'behind' : d < 0 ? 'ahead' : 'ontime'); });\n    document.querySelectorAll('.mtl-status-text').forEach(t => { t.textContent = d > 0 ? (d + ' min behind') : d < 0 ? ((-d) + ' min ahead') : 'On time'; });\n  }\n}\nfunction selectMeetingRace(n) {\n  document.querySelectorAll('.vtl-item').forEach(el => el.classList.toggle('active', +el.dataset.race === n));\n  const tabs = document.querySelectorAll('#view-steward .race-tabs-bar .race-tab');\n  tabs.forEach((t, i) => t.classList.toggle('active', i === n - 1));\n  toast('Race ' + n + ' loaded', 'green');\n}\nfunction snavTab(btn) {\n  const panel = btn.closest('.notif-panel');\n  if (!panel) return;\n  const pane = btn.dataset.pane;\n  panel.querySelectorAll('.snav-tab').forEach(t => t.classList.toggle('active', t === btn));\n  panel.querySelectorAll('.snav-pane').forEach(p => { p.style.display = (p.dataset.pane === pane ? '' : 'none'); });\n}\nfunction openTtpModal() { const m = document.getElementById('ttpModal'); if (m) m.classList.add('open'); }\nfunction closeTtpModal() { const m = document.getElementById('ttpModal'); if (m) m.classList.remove('open'); }\ndocument.addEventListener('keydown', e => { if (e.key === 'Escape') { closeTtpModal(); closeCalendar(); } });\n\n/* ─── Full calendar (fixtures + raceday-team schedule) ─── */\n// Events keyed by ISO date. type: fixture | shadow | training | meeting | leave\nconst calEvents = {\n  '2025-05-06': [{ t: 'meeting', time: '10:00', label: 'Ops pre-week briefing' }],\n  '2025-05-07': [{ t: 'training', time: '09:30', label: 'Stewarding CPD — rule updates' }],\n  '2025-05-08': [{ t: 'fixture', time: '13:50', label: 'ASCOT (jumps)' }, { t: 'shadow', time: '13:00', label: 'Shadow: A. Nolan' }],\n  '2025-05-09': [{ t: 'fixture', time: '14:10', label: 'ASCOT' }, { t: 'leave', label: 'M. Webber — leave' }],\n  '2025-05-10': [{ t: 'fixture', tim