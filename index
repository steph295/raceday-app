replace('rm-', ''), 10);\n    const meta = runnerMeta[no];\n    row.dataset.decoratedSp = '1';\n    if (!meta) return;\n    // SP pill\n    if (meta.sp) {\n      const sp = document.createElement('span');\n      sp.className = 'sp-pill' + (meta.top ? ' sp-top' : '');\n      const moveTxt = meta.move === 'in' ? '▼' : meta.move === 'out' ? '▲' : '·';\n      const moveCls = meta.move === 'in' ? 'in' : meta.move === 'out' ? 'out' : 'steady';\n      sp.title = 'Market price · was ' + (meta.prev || meta.sp) + ' · updated 14:21';\n      sp.innerHTML = '<span class=\"sp-move ' + moveCls + '\">' + moveTxt + '<\u002Fspan><span class=\"sp-num\">SP ' + _esc(meta.sp) + '<\u002Fspan>' + (meta.fav ? '<span class=\"sp-fav-mark\">F<\u002Fspan>' : '');\n      figEl.appendChild(sp);\n    }\n    // History pill\n    const h = meta.history || {};\n    const total = _histCount(h);\n    if (total > 0) {\n      const hp = document.createElement('span');\n      hp.className = 'hist-pill' + (_hasToday(h) ? ' has-today' : '');\n      hp.title = total + ' notes on file · click to open history';\n      hp.innerHTML = '<span class=\"hist-glyph\">◷<\u002Fspan>' + total + ' notes';\n      hp.setAttribute('onclick', 'event.stopPropagation();toggleHistoryDrawer(' + no + ',event)');\n      figEl.appendChild(hp);\n    }\n  });\n}\n\nfunction renderHistory(meta, stData, rowNo) {\n  const h = meta.history || {};\n  const horseName = stData ? stData.horse : '';\n  const jockeyName = stData ? stData.jockey : '';\n  const courseToday = 'Ascot';\n  const _renderList = (items, emptyMsg) => {\n    if (!items || !items.length) return '<div class=\"hist-empty\">' + _esc(emptyMsg) + '<\u002Fdiv>';\n    return '<div class=\"hist-list\">' + items.map(i => {\n      const tagHtml = i.tag ? '<span class=\"h-tag ' + i.tag + '\">' + (i.tag === 'warn' ? '⚠' : i.tag === 'cleared' ? '✓' : i.tag === 'course' ? '◆' : '●') + '<\u002Fspan>' : '';\n      return '<div class=\"hist-item ' + (i.today ? 'is-today' : '') + '\">' +\n        '<div class=\"h-date\">' + _esc(i.date) + '<\u002Fdiv>' +\n        '<div class=\"h-body\">' + tagHtml + _esc(i.text) + '<\u002Fdiv>' +\n        '<\u002Fdiv>';\n    }).join('') + '<\u002Fdiv>';\n  };\n  return ''\n    + '<div class=\"hist-head\">'\n    +   '<div>'\n    +     '<div class=\"hist-head-title\">History · No.' + rowNo + ' ' + _esc(horseName) + ' · ' + _esc(jockeyName) + '<\u002Fdiv>'\n    +     '<div class=\"hist-head-sub\">Most recent first · stewards archive · use ↗ Full archive for the complete record<\u002Fdiv>'\n    +   '<\u002Fdiv>'\n    +   '<div class=\"hist-pen-legend\">Today\\'s notes accented in blue<\u002Fdiv>'\n    + '<\u002Fdiv>'\n    + '<div class=\"hist-grid\">'\n    +   '<div class=\"hist-section\">'\n    +     '<div class=\"hist-sec-head\"><span>Horse — stewards notes<\u002Fspan><span class=\"hist-sec-count\">' + (h.horse_notes||[]).length + '<\u002Fspan><\u002Fdiv>'\n    +     _renderList(h.horse_notes, 'No previous stewards notes for this horse.')\n    +   '<\u002Fdiv>'\n    +   '<div class=\"hist-section\">'\n    +     '<div class=\"hist-sec-head\"><span>Jockey — stewards notes<\u002Fspan><span class=\"hist-sec-count\">' + (h.jockey_notes||[]).length + '<\u002Fspan><\u002Fdiv>'\n    +     _renderList(h.jockey_notes, 'No previous stewards notes for this jockey.')\n    +   '<\u002Fdiv>'\n    +   '<div class=\"hist-section\">'\n    +     '<div class=\"hist-sec-head\"><span>This horse at ' + courseToday + '<\u002Fspan><span class=\"hist-sec-count\">' + (h.course||[]).length + '<\u002Fspan><\u002Fdiv>'\n    +     _renderList(h.course, 'No previous runs at this course.')\n    +   '<\u002Fdiv>'\n    +   '<div class=\"hist-section\">'\n    +     '<div class=\"hist-sec-head\"><span>Jockey · previous-meeting reports<\u002Fspan><span class=\"hist-sec-count\">' + (h.jockey_reports||[]).length + '<\u002Fspan><\u002Fdiv>'\n    +     _renderList(h.jockey_reports, 'No previous-meeting reports for this jockey.')\n    +   '<\u002Fdiv>'\n    + '<\u002Fdiv>'\n    + '<div class=\"hist-footer\">'\n    +   '<span>Filtered to last 24 months · most relevant first<\u002Fspan>'\n    +   '<span class=\"hist-link\" onclick=\"event.stopPropagation();toast(\\'Full archive — would open in a separate workspace\\',\\'blue\\')\">Open full archive →<\u002Fspan>'\n    + '<\u002Fdiv>';\n}\n\nfunction toggleHistoryDrawer(rowNo, evt) {\n  if (evt) evt.stopPropagation();\n  const drawer = document.getElementById('cd-' + rowNo);\n  if (!drawer) return;\n  const same = connOpen && connOpen.rowNo === rowNo && connOpen.type === 'history';\n  closeAllConnDrawers();\n  if (same) { connOpen = null; return; }\n  const meta = runnerMeta[rowNo];\n  const stData = (typeof stRunnerData !== 'undefined') ? stRunnerData[rowNo] : null;\n  if (!meta) return;\n  const html = renderHistory(meta, stData, rowNo);\n  drawer.innerHTML = '<button class=\"stew-drawer-close\" onclick=\"event.stopPropagation();toggleHistoryDrawer(' + rowNo + ',event)\" aria-label=\"Close\">✕<\u002Fbutton><div class=\"stew-drawer-inner\" style=\"grid-template-columns: 1fr; padding: 18px 56px 18px 78px; display: block;\">' + html + '<\u002Fdiv>';\n  drawer.classList.add('open');\n  const row = drawer.previousElementSibling;\n  if (row) {\n    const trigger = row.querySelector('.hist-pill');\n    if (trigger) trigger.classList.add('is-active');\n  }\n  connOpen = { rowNo, type: 'history' };\n}\n\n/* Market offline simulator (demo) */\nfunction toggleMarketOffline() {\n  const bar = document.getElementById('marketStatus');\n  const btn = document.getElementById('msToggle');\n  const off = bar.classList.toggle('offline');\n  // Tag all sp-pills as stale\n  document.querySelectorAll('.stew-horse-fig .sp-pill').forEach(p => p.classList.toggle('stale', off));\n  if (off) {\n    bar.querySelector('span:nth-of-type(3)').innerHTML = '⚠ Offline · last known prices from <b id=\"msTime\">14:21<\u002Fb> · refresh paused';\n    btn.textContent = 'Simulate live';\n  } else {\n    bar.querySelector('span:nth-of-type(3)').innerHTML = 'Live · last update <b id=\"msTime\">14:21<\u002Fb> · <span style=\"color:var(--red);font-weight:700;\">top 4 prices in red<\u002Fspan> (paper-card convention)';\n    btn.textContent = 'Simulate offline';\n  }\n}\n\n// Decorate runners on init + re-decorate when the steward view becomes active\ndecorateStewRunners();\n\n/* ─────  Starter notes data + render  ───── */\nconst starterData = {\n  1: {summary:'Clean break', tone:'ok',    note:'Walked in calmly, stood square. Broke on terms with rest of field.', stall:1, behaviour:'Settled', vet:'No issue', recorded:'14:12 · S. Murray (Starter)', flags:[]},\n  2: {summary:'Clean break', tone:'ok',    note:'Loaded second, no concerns. Quick away when gates opened.', stall:6, behaviour:'Settled', vet:'No issue', recorded:'14:11 · S. Murray (Starter)', flags:[]},\n  3: {summary:'Slow to break · jumped sideways', tone:'amber', note:'Reluctant to load. Once in stalls, leaned heavily on near-side door. Jumped sideways at start, lost 1½ lengths. Possibly contributory to interference noted in straight.', stall:3, behaviour:'Reluctant', vet:'Cleared by veterinary surgeon at 13:58', recorded:'14:14 · S. Murray (Starter)', flags:['Linked to R3 enquiry']},\n  4: {summary:'Clean break', tone:'ok',    note:'Standard load. Broke evenly.', stall:8, behaviour:'Settled', vet:'No issue', recorded:'14:11 · S. Murray (Starter)', flags:[]},\n  5: {summary:'Reared in stalls', tone:'red', note:'Reared once during loading and again immediately before gates opened. Veterinary surgeon attended; cleared to start. Broke flat-footed and trailed early.', stall:5, behaviour:'Fractious', vet:'Cleared by veterinary surgeon at 14:09', recorded:'14:13 · S. Murray (Starter)', flags:['Sampling selected post-race']},\n  6: {summary:'Clean break', tone:'ok',    note:'Walked in, stood quietly, broke well.', stall:2, behaviour:'Settled', vet:'No issue', recorded:'14:11 · S. Murray (Starter)', flags:[]},\n  7: {summary