ce(/\\s*\\([^)]*\\)\\s*$/, '');\n  const jockey = row.children[2] && row.children[2].querySelector('div:first-child') ? row.children[2].querySelector('div:first-child').textContent.trim() : '';\n  const html = ''\n    + '<button class=\"sds-history-close\" onclick=\"closeSdsHistory()\" aria-label=\"Close\">✕<\u002Fbutton>'\n    + '<div class=\"hist-head\">'\n    +   '<div>'\n    +     '<div class=\"hist-head-title\">History · ' + _sdsEsc(horseShort) + ' · ' + _sdsEsc(jockey) + '<\u002Fdiv>'\n    +     '<div class=\"hist-head-sub\">Most recent first · stewards archive · last 24 months<\u002Fdiv>'\n    +   '<\u002Fdiv>'\n    +   '<div class=\"hist-pen-legend\">Today\\'s notes accented in blue<\u002Fdiv>'\n    + '<\u002Fdiv>'\n    + '<div class=\"hist-grid\">'\n    +   '<div class=\"hist-section\"><div class=\"hist-sec-head\"><span>Horse — stewards notes<\u002Fspan><span class=\"hist-sec-count\">' + (h.horse||[]).length + '<\u002Fspan><\u002Fdiv>' + _sdsRenderList(h.horse, 'No previous stewards notes for this horse.') + '<\u002Fdiv>'\n    +   '<div class=\"hist-section\"><div class=\"hist-sec-head\"><span>Jockey — stewards notes<\u002Fspan><span class=\"hist-sec-count\">' + (h.jockey||[]).length + '<\u002Fspan><\u002Fdiv>' + _sdsRenderList(h.jockey, 'No previous stewards notes for this jockey.') + '<\u002Fdiv>'\n    +   '<div class=\"hist-section\"><div class=\"hist-sec-head\"><span>This horse at Ascot<\u002Fspan><span class=\"hist-sec-count\">' + (h.course||[]).length + '<\u002Fspan><\u002Fdiv>' + _sdsRenderList(h.course, 'No previous runs at this course.') + '<\u002Fdiv>'\n    +   '<div class=\"hist-section\"><div class=\"hist-sec-head\"><span>Jockey · previous-meeting reports<\u002Fspan><span class=\"hist-sec-count\">' + (h.reports||[]).length + '<\u002Fspan><\u002Fdiv>' + _sdsRenderList(h.reports, 'No previous-meeting reports for this jockey.') + '<\u002Fdiv>'\n    + '<\u002Fdiv>'\n    + '<div class=\"hist-footer\">'\n    +   '<span>Filtered to last 24 months · most relevant first<\u002Fspan>'\n    +   '<span class=\"hist-link\" onclick=\"event.stopPropagation();toast(\\'Full archive — would open in a separate workspace\\',\\'blue\\')\">Open full archive →<\u002Fspan>'\n    + '<\u002Fdiv>';\n  const drawer = document.createElement('div');\n  drawer.className = 'sds-history-row open';\n  drawer.innerHTML = html;\n  row.insertAdjacentElement('afterend', drawer);\n  if (pill) pill.classList.add('is-active');\n  sdsHistOpenRow = row;\n}\n\nfunction sdsToggleOffline() {\n  const bar = document.getElementById('sdsMarketStatus');\n  const btn = document.getElementById('sdsMsToggle');\n  if (!bar) return;\n  const off = bar.classList.toggle('offline');\n  document.querySelectorAll('.sds-sp-mark').forEach(s => s.classList.toggle('stale', off));\n  const txt = bar.querySelector('span:nth-of-type(3)');\n  if (off) {\n    txt.innerHTML = '⚠ Offline · last known prices from <b>14:21<\u002Fb> · refresh paused';\n    btn.textContent = 'Simulate live';\n  } else {\n    txt.innerHTML = 'Live · last update <b>14:21<\u002Fb> · <span style=\"color:var(--red);font-weight:700;\">top 4 prices per race in red<\u002Fspan> (paper-card convention)';\n    btn.textContent = 'Simulate offline';\n  }\n}\n\nfunction sdsToggleAllRaces() {\n  const bodies = document.querySelectorAll('#view-steward-daysheet .sds-race .ds-body');\n  // Determine target state: if any are collapsed, expand all; else collapse all\n  const anyCollapsed = [...bodies].some(b => b.style.display === 'none' || getComputedStyle(b).display === 'none');\n  bodies.forEach(b => { b.style.display = anyCollapsed ? 'block' : 'none'; });\n  const btn = document.getElementById('sdsExpandAllBtn');\n  const lbl = document.getElementById('sdsExpandAllLabel');\n  if (anyCollapsed) {\n    lbl.textContent = 'Collapse all races';\n    btn.classList.add('on');\n  } else {\n    lbl.textContent = 'Expand all races';\n    btn.classList.remove('on');\n    closeSdsHistory();\n  }\n}\n\nfunction toggleSsClear() {\n  const btn = document.getElementById('ssClearToggle');\n  if (!btn) return;\n  const currentlyOn = btn.getAttribute('aria-pressed') === 'true';\n  if (currentlyOn) {\n    // Withdrawing clearance — immediate, no confirmation\n    btn.setAttribute('aria-pressed', 'false');\n    const txt = document.getElementById('ssClearText');\n    if (txt) txt.textContent = 'Stewards Clear';\n    closeSsConfirm();\n    toast('SS clearance withdrawn — race re-opened', 'amber');\n    return;\n  }\n  // Toggling ON — show confirm popover, only commit on confirm\n  openSsConfirm(btn);\n}\n\nfunction openSsConfirm(anchorBtn) {\n  closeSsConfirm();\n  const pop = document.createElement('div');\n  pop.className = 'ss-confirm-popover';\n  pop.id = 'ssConfirmPop';\n  pop.innerHTML =\n    '<div class=\"ss-confirm-head\"><span class=\"ss-confirm-glyph\">✓<\u002Fspan>Ready to publish Stewards Clear?<\u002Fdiv>' +\n    '<div class=\"ss-confirm-body\">Confirms <b>SS<\u002Fb> for R3 Queen Anne Stakes — stewards satisfied. Result becomes official and is broadcast to team.<\u002Fdiv>' +\n    '<div class=\"ss-confirm-recips\">' +\n      '<div class=\"scr-row\"><span class=\"scr-tick\">✓<\u002Fspan><span class=\"scr-label\">Judges<\u002Fspan><span>· result locked<\u002Fspan><\u002Fdiv>' +\n      '<div class=\"scr-row\"><span class=\"scr-tick\">✓<\u002Fspan><span class=\"scr-label\">Scales<\u002Fspan><span>· weigh-in unlocked<\u002Fspan><\u002Fdiv>' +\n      '<div class=\"scr-row\"><span class=\"scr-tick\">✓<\u002Fspan><span class=\"scr-label\">Race control<\u002Fspan><span>· next race cleared to load<\u002Fspan><\u002Fdiv>' +\n      '<div class=\"scr-row\"><span class=\"scr-tick\">✓<\u002Fspan><span class=\"scr-label\">Broadcast<\u002Fspan><span>· \"SS confirmed\" graphic<\u002Fspan><\u002Fdiv>' +\n    '<\u002Fdiv>' +\n    '<div class=\"ss-confirm-actions\">' +\n      '<button class=\"ss-confirm-btn\" onclick=\"closeSsConfirm()\">Cancel<\u002Fbutton>' +\n      '<button class=\"ss-confirm-btn primary\" onclick=\"commitSsClear()\">Publish to team<\u002Fbutton>' +\n    '<\u002Fdiv>';\n  document.body.appendChild(pop);\n  // Position below the button\n  const r = anchorBtn.getBoundingClientRect();\n  pop.style.top = (r.bottom + 10) + 'px';\n  pop.style.left = Math.max(8, Math.min(window.innerWidth - 328, r.right - 320)) + 'px';\n  // Outside-click to close\n  setTimeout(() => {\n    document.addEventListener('click', _ssConfirmOutside, true);\n    document.addEventListener('keydown', _ssConfirmEsc);\n  }, 0);\n}\nfunction _ssConfirmOutside(e) {\n  const pop = document.getElementById('ssConfirmPop');\n  if (!pop) return;\n  if (pop.contains(e.target)) return;\n  if (e.target.closest('#ssClearToggle')) return;\n  closeSsConfirm();\n}\nfunction _ssConfirmEsc(e) {\n  if (e.key === 'Escape') closeSsConfirm();\n}\nfunction closeSsConfirm() {\n  const pop = document.getElementById('ssConfirmPop');\n  if (pop) pop.remove();\n  document.removeEventListener('click', _ssConfirmOutside, true);\n  document.removeEventListener('keydown', _ssConfirmEsc);\n}\nfunction commitSsClear() {\n  const btn = document.getElementById('ssClearToggle');\n  if (btn) btn.setAttribute('aria-pressed', 'true');\n  const txt = document.getElementById('ssClearText');\n  if (txt) txt.textContent = 'Stewards Cleared';\n  closeSsConfirm();\n  toast('SS confirmed · published to Judges, Scales, Race Control, Broadcast', 'green');\n}\n\ndecorateSdsRows();\nensureSdsTableHead();\nensureRaceChevrons();\nensureRunnerIndent();\n// Other teams column on by default (checkboxes start checked)\n['starter', 'clerk', 'handicapper'].forEach(t => document.body.classList.add('show-team-' + t));\n// Privileges filter on by default — highlight every privilege (checkboxes start checked)\n['redhood', 'mountedtrack', 'mountstart', 'earlypost', 'blinkers', 'tonguetie'].forEach(p => document.body.classList.add('show-priv-' + p));\nif (typeof recomputeTeamsCol === 'function') recomputeTeamsCol();\n['fbTeamsMenu', 'fbPrivMenu'].forEach(id => { if (typeof _syncAll === 'function') _syncAll(id); });\napplySdsGrid();\n// Mark initially-collapsed races so chevron points right\ndocument.querySelectorAll('#sds-races .sds-race').forEach(r => {\n  const body = r.querySelector('.ds-body');\n  if (body && (body.style.display === 'none' || getComputedStyle(body).display === 'none')) {\n    r.classList.add('collapsed');\n  }\n});\n\ndocument.addEventListener('click', e => {\n  if (sdsHistOpenRow && !e.target.closest('.sds-history-row') && !e.target.closest('.sds-hist-pill')) closeSdsHistory();\n}, true);\ndocument.addEventListener('keydown', e => {\n  if (e.key === 'Escape' && sdsHistOpenRow) closeSdsHistory();\n});\n\n/* ─────  Publish to X / Twitter inline action  ───── */\nconst X_MAX = 280;\nfunction _xEsc(s){ return String(s).replace(/[&<>\"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',\"'\":'&#39;'}[c])); }\n\nfunction decorateAstFeedPublish() {\n  document.querySelectorAll('#view-assistant .ast-feed-entry').forEach(entry => {\n    if (entry.dataset.publishDecorated) return;\n    entry.dataset.publishDecorated = '1';\n    const body = entry.querySelector('.ast-feed-body');\n    if (!body) return;\n\n    // Already-published entries (historical audit trail)\n    if (entry.hasAttribute('data-published-tweet')) {\n      const time = entry.getAttribute('data-published-time') || '';\n      const tweet = entry.getAttribute('data-published-tweet') || '';\n      const pillRow = document.createElement('div');\n      pillRow.className = 'ast-publish-row';\n      pillRow.innerHTML =\n        '<span class=\"ast-publish-pill\"><span class=\"x-glyph\">𝕏<\u002Fspan>✓ Published to X<span class=\"pp-time\"> · ' + _xEsc(time) + '<\u002Fspan><\u002Fspan>';\n      body.appendChild(pillRow);\n      const quote = document.createElement('div');\n      quote.className = 'ast-publish-tweet';\n      quote.textContent = tweet;\n      body.appendChild(quote);\n      return;\n    }\n\n    if (!entry.hasAttribute('data-publishable')) return;\n    const suggested = entry.getAttribute('data-suggested') || (body.querySelector('.ast-feed-text')?.textContent || body.textContent || '').slice(0, X_MAX);\n    const row = document.createElement('div');\n    row.className = 'ast-publish-row';\n    row.innerHTML = '<button class=\"ast-publish-btn\" type=\"button\"><span class=\"x-glyph\">𝕏<\u002Fspan>Publish to X<\u002Fbutton>';\n    row.querySelector('button').addEventListener('click', (e) => { e.stopPropagation(); openComposeFor(entry, suggested); });\n    body.appendChild(row);\n  });\n}\n\nfunction openComposeFor(entry, suggested) {\n  // Close any other open compose panels\n  document.querySelectorAll('.ast-publish-compose').forEach(c => c.remove());\n  document.querySelectorAll('.ast-publish-row').forEach(r => r.style.display = '');\n  const body = entry.querySelector('.ast-feed-body');\n  if (!body) return;\n  const row = entry.querySelector('.ast-publish-row');\n  if (row) row.style.display = 'none';\n\n  const compose = document.createElement('div');\n  compose.className = 'ast-publish-compose';\n  compose.innerHTML =\n    '<div class=\"pc-head\">' +\n      '<div class=\"pc-avatar\">𝕏<\u002Fdiv>' +\n      '<div>' +\n        '<div class=\"pc-from\">@AscotStewards<\u002Fdiv>' +\n        '<div class=\"pc-from-sub\">Stewards Room · official racecourse account<\u002Fdiv>' +\n      '<\u002Fdiv>' +\n      '<div class=\"pc-warn\">Manual approval required<\u002Fdiv>' +\n    '<\u002Fdiv>' +\n    '<textarea class=\"pc-text\" rows=\"3\"><\u002Ftextarea>' +\n    '<div class=\"pc-footer\">' +\n      '<div class=\"pc-count-bar\" aria-hidden=\"true\"><\u002Fdiv>' +\n      '<div class=\"pc-count\">0 / ' + X_MAX + '<\u002Fdiv>' +\n      '<div class=\"pc-spacer\"><\u002Fdiv>' +\n      '<button class=\"pc-btn pc-cancel\" type=\"button\">Cancel<\u002Fbutton>' +\n      '<button class=\"pc-btn primary pc-confirm\" type=\"button\">Publish to X<\u002Fbutton>' +\n    '<\u002Fdiv>';\n  body.appendChild(compose);\n  const ta = compose.querySelector('.pc-text');\n  ta.value = suggested;\n  ta.focus();\n  ta.setSelectionRange(ta.value.length, ta.value.length);\n\n  const update = () => {\n    const len = ta.value.length;\n    const cnt = compose.querySelector('.pc-count');\n    const bar = compose.querySelector('.pc-count-bar');\n    cnt.textContent = len + ' / ' + X_MAX;\n    cnt.classList.remove('warn', 'over');\n    if (len > X_MAX) cnt.classList.add('over');\n    else if (len > X_MAX - 30) cnt.classList.add('warn');\n    bar.style.setProperty('--pc-pct', Math.min(100, (len / X_MAX) * 100));\n    compose.querySelector('.pc-confirm').disabled = (len === 0 || len > X_MAX);\n  };\n  ta.addEventListener('input', update);\n  update();\n\n  compose.querySelector('.pc-cancel').addEventListener('click', (e) => {\n    e.stopPropagation();\n    compose.remove();\n    if (row) row.style.display = '';\n  });\n  compose.querySelector('.pc-confirm').addEventListener('click', (e) => {\n    e.stopPropagation();\n    publishToX(entry, ta.value.trim());\n  });\n}\n\nfunction publishToX(entry, text) {\n  const now = new Date();\n  const time = ('0' + now.getHours()).slice(-2) + ':' + ('0' + now.getMinutes()).slice(-2);\n  // Remove compose + old row\n  entry.querySelectorAll('.ast-publish-compose, .ast-publish-row, .ast-publish-tweet').forEach(n => n.remove());\n  const body = entry.querySelector('.ast-feed-body');\n  const row = document.createElement('div');\n  row.className = 'ast-publish-row';\n  row.innerHTML = '<span class=\"ast-publish-pill\"><span class=\"x-glyph\">𝕏<\u002Fspan>✓ Published to X<span class=\"pp-time\"> · ' + _xEsc(time) + '<\u002Fspan><\u002Fspan>';\n  body.appendChild(row);\n  const quote = document.createElement('div');\n  quote.className = 'ast-publish-tweet';\n  quote.textContent = text;\n  body.appendChild(quote);\n  toast('Published to @AscotStewards on X', 'green');\n}\n\ndecorateAstFeedPublish();\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
